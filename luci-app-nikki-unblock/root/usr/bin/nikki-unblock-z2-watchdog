#!/bin/sh
# nikki-unblock: self-heal zapret2's DPI-bypass rules on OpenWrt fw4.
#
# On fw4 (nftables) the zapret2 desync nft rules come from the firewall include and are (re)built only on
# a full restart / fw reload — a bare `start` (or a stop->start / off->on toggle) brings nfqws2 up but
# leaves NO desync rules. Symptom: the service reads "running" yet nothing is bypassed (video/googlevideo
# breaks). This watchdog notices that state (zapret2 enabled, but its desync queue absent or nfqws2 down)
# and does a full restart, which rebuilds both. Runs from cron every few minutes; only acts when zapret2
# is ENABLED — to keep it off for testing, `disable` zapret2 (not just stop).
[ -x /etc/init.d/zapret2 ] || exit 0
/etc/init.d/zapret2 enabled 2>/dev/null || exit 0
q=$(nft list chain inet zapret2 postnat 2>/dev/null | grep -c 'queue')
r=0; pgrep -f nfqws2 >/dev/null 2>&1 && r=1
if [ "$q" = 0 ] || [ "$r" = 0 ]; then
	logger -t nikki-unblock-z2wd "zapret2 desync missing (queue=$q running=$r) -> restart"
	/etc/init.d/zapret2 restart
fi
