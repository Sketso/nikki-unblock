#!/bin/sh
# Post-install wiring for nikki-unblock.

# CGI must be executable (package files usually keep mode, but be safe).
[ -f /www/cgi-bin/nikki-unblock ] && chmod 0755 /www/cgi-bin/nikki-unblock

# node store for the VPN-nodes tab (root-only; holds keys)
mkdir -p /etc/nikki-unblock/nodes /etc/nikki-unblock/providers /etc/nikki-unblock/subs
chmod 700 /etc/nikki-unblock /etc/nikki-unblock/nodes /etc/nikki-unblock/providers /etc/nikki-unblock/subs 2>/dev/null

# Seed the config section if it is somehow missing (the shipped /etc/config/nikki-unblock covers this).
if ! uci -q get nikki-unblock.config >/dev/null 2>&1; then
	touch /etc/config/nikki-unblock
	uci -q set nikki-unblock.config=nikki-unblock
	uci -q set nikki-unblock.config.applist_url='https://sketso.github.io/nikki-unblock/applist'
	uci -q set nikki-unblock.config.autosync_enabled='0'
	uci -q set nikki-unblock.config.autosync_interval='24h'
	uci -q set nikki-unblock.config.lang='ru'
	uci -q set nikki-unblock.config.base_group='PROXY'
	uci -q set nikki-unblock.config.exit_group='UNBLOCK'
	uci -q set nikki-unblock.config.node_mode='fallback'
	uci -q commit nikki-unblock
fi

# Drop any stale autosync cron line from the predecessor CGI (nikki-domains), if present.
[ -f /etc/crontabs/root ] && sed -i '/nikki-domains/d' /etc/crontabs/root && /etc/init.d/cron restart >/dev/null 2>&1

# One-time: seed the exit-node mode + build the managed exit group (UNBLOCK) so "→ VPN" rules resolve.
# Idempotent via a flag; runs the CGI's `regen` (queries mihomo for the profile's node names).
if [ "$(uci -q get nikki-unblock.config._nodes_init 2>/dev/null)" != 1 ]; then
	uci -q set nikki-unblock.config.node_mode='fallback'
	uci -q set nikki-unblock.config._nodes_init='1'
	uci -q commit nikki-unblock
	if [ -x /www/cgi-bin/nikki-unblock ] && pgrep -f /usr/bin/mihomo >/dev/null 2>&1; then
		/www/cgi-bin/nikki-unblock regen 2>/dev/null
		/etc/init.d/nikki reload >/dev/null 2>&1
	fi
fi

# Refresh the LuCI menu/index cache so the new entry shows up.
rm -f /tmp/luci-indexcache* 2>/dev/null
rm -rf /tmp/luci-modulecache 2>/dev/null

exit 0
