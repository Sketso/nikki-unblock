config nikki-unblock 'config'
	# Where the preset manifest (index.json) + domain lists are fetched from (server-side).
	# Default = the project's neutral GitHub Pages host. Point it at your own if you self-host.
	option applist_url 'https://sketso.github.io/nikki-unblock/applist'
	# Auto-sync of enabled domain-list presets (executed by cron). Light + nightly by default.
	option autosync_enabled '0'
	option autosync_interval '24h'
	# UI default language: ru | en  (each browser can override via the RU/EN switch).
	option lang 'ru'
	# VPN nodes tab: the profile's existing exit proxy-group (added nodes are pooled together with it).
	# Set this to your mihomo profile's proxy-group name if it isn't "PROXY".
	option base_group 'PROXY'
	# Name of the managed exit group (ordered profile + added nodes) that "→ VPN" rules target.
	option exit_group 'UNBLOCK'
	# Exit-node selection: 'fallback' (priority order, top-first) or 'urltest' (auto lowest-latency).
	option node_mode 'fallback'
	# Auto-refresh tracked link-subscriptions on a schedule (on by default; cron created once a sub exists).
	option subauto '1'
	option subauto_interval '24h'
	# Device list mode for each engine — managed from the panel's Общее → Устройства tab.
	# 'exclude' (default): listed devices bypass the engine, everyone else goes through it.
	# 'only': the engine applies ONLY to listed devices, everyone else bypasses it.
	option nikki_device_mode 'exclude'
	option z2_device_mode 'exclude'
	# Devices are identified by MAC (not IP) since IP drifts without a DHCP reservation, which most
	# friends never set up. A stale exclusion by IP silently starts matching the wrong device.
	#
	# LAN devices whose traffic skips the zapret2 desync (or, in 'only' mode, are the only ones
	# desynced). zapret2 can't filter by client itself (its hook runs after NAT), so the panel marks
	# these MACs pre-NAT with DESYNC_MARK, which makes zapret2 skip (or, inverted, target) them.
	#   list z2_bypass_mac 'aa:bb:cc:dd:ee:ff'
	# One-time marker: has the old IP-keyed z2_bypass_ip / nikki lan_access_control.ip data already
	# been migrated to MAC? Set by the panel itself on first request after upgrade; don't hand-edit.
	option dev_mac_migrated '0'
	# Optional PIN gate for the panel + /unblock page (OFF by default). Set from Общее → Безопасность:
	# stores only a salted sha256 hash (pin_salt / pin_hash), never the PIN itself. Over plain http this
	# keeps casual/guest LAN users out, but is not protection against someone sniffing the network.
	option auth_enabled '0'
