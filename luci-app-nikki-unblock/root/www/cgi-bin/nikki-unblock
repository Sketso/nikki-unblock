# Unified exit list as JSON — NEVER includes secrets. Shape:
# {mode, active, nodes:[{name,kind,id,type,host,enabled,active}], providers:[{id,name,count}]}
# nodes[] = ordered union of profile nodes (kind:profile, id="") + our nodes (kind:node, id=file).
nodes_json() {
	json_header
	sec=$(mihomo_secret)
	active=$(curl -s -m 6 -H "Authorization: Bearer $sec" "$MIHOMO_API/proxies/$(urlenc_all "$EXIT_GROUP")" 2>/dev/null | jsonfilter -e '@.now' 2>/dev/null)
	# map: our node NAME -> "id\ttype\thost\tsubname" (so we can tag ordered names as ours)
	OM="/tmp/nu-omap.$$"; : > "$OM"
	for f in "$NODES_DIR"/*.yaml; do
		[ -f "$f" ] || continue
		fn=$(grep -m1 'name:' "$f" | sed 's/.*name:[[:space:]]*//')
		fty=$(grep -m1 'type:' "$f" | sed 's/.*type:[[:space:]]*//')
		fhs=$(grep -m1 'server:' "$f" | sed 's/.*server:[[:space:]]*//')
		fid=$(basename "$f" .yaml); fsub=""
		[ -f "$NODES_DIR/$fid.src" ] && fsub=$(grep -m1 '^name=' "$SUBS_DIR/$(cat "$NODES_DIR/$fid.src").conf" 2>/dev/null | cut -d= -f2-)
		printf '%s\t%s\t%s\t%s\t%s\n' "$fn" "$fid" "$fty" "$fhs" "$fsub" >> "$OM"
	done
	# legacy = rules still routed at the raw profile group (candidates for the "migrate" button)
	legacy=$(uci show nikki 2>/dev/null | grep -c "\.node='$BASE_GROUP'\$")
	z2=0; zapret2_present && z2=1
	printf '{"mode":"%s","active":"%s","legacy":%s,"zapret2":%d,"nodes":[' "$(node_mode)" "$(json_esc "$active")" "${legacy:-0}" "$z2"
	first=1
	ordered_exit_names | while IFS= read -r nm; do
		[ -z "$nm" ] && continue
		row=$(grep -m1 -F "$(printf '%s\t' "$nm")" "$OM" 2>/dev/null)
		if [ -n "$row" ]; then
			kind=node; id=$(printf '%s' "$row" | cut -f2); ty=$(printf '%s' "$row" | cut -f3); hs=$(printf '%s' "$row" | cut -f4); sb=$(printf '%s' "$row" | cut -f5)
		else
			kind=profile; id=""; ty=""; hs=""; sb=""
		fi
		en=1; node_disabled "$nm" && en=0
		act=0; [ "$nm" = "$active" ] && act=1
		[ "$first" = 1 ] || printf ','; first=0
		printf '{"name":"%s","kind":"%s","id":"%s","type":"%s","host":"%s","sub":"%s","enabled":%s,"active":%s}' \
			"$(json_esc "$nm")" "$kind" "$id" "$(json_esc "$ty")" "$(json_esc "$hs")" "$(json_esc "$sb")" "$en" "$act"
	done
	rm -f "$OM"
	printf '],"providers":['
	first=1
	# tracked link-subscriptions (refreshable; their nodes are the individual ones above)
	for f in "$SUBS_DIR"/*.conf; do
		[ -f "$f" ] || continue
		sid=$(basename "$f" .conf); snm=$(grep -m1 '^name=' "$f" | cut -d= -f2-)
		[ "$first" = 1 ] || printf ','; first=0
		printf '{"id":"%s","name":"%s","count":%s,"kind":"sub"}' "$sid" "$(json_esc "$snm")" "$(sub_owned_ids "$sid" | grep -c .)"
	done
	# clash proxy-providers (auto-updating bundles; all-or-nothing)
	for f in "$PROV_DIR"/*.yaml; do
		[ -f "$f" ] || continue
		nm=$(head -1 "$f" | sed 's/[[:space:]]*\([^:]*\):.*/\1/')
		cnt=$(curl -s -m 6 -H "Authorization: Bearer $sec" "$MIHOMO_API/providers/proxies" 2>/dev/null | jsonfilter -e "@.providers[\"$nm\"].proxies[*].name" 2>/dev/null | grep -c .)
		[ "$first" = 1 ] || printf ','; first=0
		printf '{"id":"%s","name":"%s","count":%s,"kind":"provider"}' "$(basename "$f" .yaml)" "$(json_esc "$nm")" "${cnt:-0}"
	done
	printf ']}'
}

# cron / CLI entry: `nikki-unblock sync`
[ "$1" = "sync" ] && { sync_all; exit 0; }
# CLI: rebuild the managed exit-group mixin (used by post-install to create UNBLOCK once)
[ "$1" = "regen" ] && { regen_mixin; exit 0; }
# cron/CLI: refresh all tracked link-subscriptions (add/update/remove nodes)
[ "$1" = "subsync" ] && { subrefresh_all; exit 0; }
# cron/CLI: write a rotating auto-backup (daily/weekly/monthly)
[ "$1" = "backupauto" ] && { backup_auto_run; exit 0; }
[ "$1" = "z2backupauto" ] && { z2_backup_auto_run; exit 0; }
# detached update runner hooks (called from the generated update script; stdout → shared update log)
[ "$1" = "z2update" ] && { z2_run_update "$2" "$3"; exit $?; }
# detached atomic nikki-preset apply (both facets) — status streamed to $PRESET_OP
[ "$1" = "_presetapply" ] && { preset_apply_run "$2" "$3" "$4" "$5" "$6" "$7" "$8" "$9"; exit 0; }
[ "$1" = "_z2presetapply" ] && { z2_preset_apply_run "$2" "$3" "$4"; exit 0; }
# nikki update rollback point: snapshot config before, restore it if mihomo dies after
NIKKI_PRESNAP="/tmp/nu-preupd-nikki.tgz"
[ "$1" = "_nikkisnap" ] && { build_backup "$NIKKI_PRESNAP" >/dev/null 2>&1 && echo ">> nikki config snapshot saved" || echo "!! snapshot failed"; exit 0; }
[ "$1" = "_nikkirollback" ] && {
	[ -f "$NIKKI_PRESNAP" ] || { echo "!! no snapshot to roll back from"; exit 1; }
	_rd="/tmp/nu-nikkirb.$$"; rm -rf "$_rd"; mkdir -p "$_rd"; tar -xzf "$NIKKI_PRESNAP" -C "$_rd" 2>/dev/null
	restore_backup "$_rd" >/dev/null 2>&1; _rc=$?
	rm -rf "$_rd"
	[ "$_rc" = 0 ] && echo ">> nikki config restored from snapshot" || echo "!! config restore reported problems (rc=$_rc)"
	exit 0
}

# ---- API -------------------------------------------------------------------

migrate_dev_ip_to_mac

API=$(printf '%s' "$QUERY_STRING" | tr '&' '\n' | grep '^api=' | head -1 | cut -d= -f2-)

# ---- backup download (GET): stream the tar.gz with attachment headers ------
[ "$API" = "backup" ] && [ "$REQUEST_METHOD" != "POST" ] && {
	bk=$(build_backup)
	printf 'Status: 200 OK\r\nContent-Type: application/gzip\r\nContent-Disposition: attachment; filename="nipret-backup.tar.gz"\r\n\r\n'
	cat "$bk"; exit 0
}
# ---- restore (POST, RAW tar.gz body — handled before urlencoded parsing) ----
[ "$API" = "restore" ] && [ "$REQUEST_METHOD" = "POST" ] && {
	json_header
	# body + extraction both land in tmpfs — refuse honestly instead of failing halfway
	fs_has_room /tmp $(( ${CONTENT_LENGTH:-0} / 512 + 1024 )) || { printf '{"ok":false,"error":"no space in /tmp"}'; exit 0; }
	bk="/tmp/nu-rst.$$.tgz"; head -c "${CONTENT_LENGTH:-0}" > "$bk"
	rd="/tmp/nu-rst.$$"; rm -rf "$rd"; mkdir -p "$rd"
	tar -xzf "$bk" -C "$rd" 2>/dev/null || { rm -rf "$bk" "$rd"; printf '{"ok":false,"error":"corrupt archive"}'; exit 0; }
	if [ ! -f "$rd/nikki.uci" ]; then rm -rf "$bk" "$rd"; printf '{"ok":false,"error":"not a valid backup"}'; exit 0; fi
	restore_backup "$rd"; rc=$?
	rm -f "$bk"; rm -rf "$rd"
	case "$rc" in
		0) printf '{"ok":true}' ;;
		2) printf '{"ok":false,"error":"restore broke mihomo (reverted)"}' ;;
		*) printf '{"ok":false,"error":"restore failed"}' ;;
	esac
	exit 0
}

# ---- zapret2 backup download / restore (same raw-body pattern as the nikki one) ----
[ "$API" = "z2backup" ] && [ "$REQUEST_METHOD" != "POST" ] && {
	bk=$(z2_build_backup)
	printf 'Status: 200 OK\r\nContent-Type: application/gzip\r\nContent-Disposition: attachment; filename="nipret-zapret2-backup.tar.gz"\r\n\r\n'
	cat "$bk"; exit 0
}
[ "$API" = "z2restore" ] && [ "$REQUEST_METHOD" = "POST" ] && {
	json_header
	fs_has_room /tmp $(( ${CONTENT_LENGTH:-0} / 512 + 1024 )) || { printf '{"ok":false,"error":"no space in /tmp"}'; exit 0; }
	bk="/tmp/nu-z2rst.$$.tgz"; head -c "${CONTENT_LENGTH:-0}" > "$bk"
	rd="/tmp/nu-z2rst.$$"; rm -rf "$rd"; mkdir -p "$rd"
	tar -xzf "$bk" -C "$rd" 2>/dev/null || { rm -rf "$bk" "$rd"; printf '{"ok":false,"error":"corrupt archive"}'; exit 0; }
	if [ ! -f "$rd/z2-manifest.json" ]; then rm -rf "$bk" "$rd"; printf '{"ok":false,"error":"not a zapret2 backup"}'; exit 0; fi
	z2_restore_backup "$rd"; rc=$?
	rm -f "$bk"; rm -rf "$rd"
	case "$rc" in
		0) printf '{"ok":true}' ;;
		2) printf '{"ok":false,"error":"restore broke zapret2 (reverted)"}' ;;
		*) printf '{"ok":false,"error":"restore failed"}' ;;
	esac
	exit 0
}

if [ "$REQUEST_METHOD" = "POST" ]; then
	DATA=$(head -c "${CONTENT_LENGTH:-0}")
	action=$(get_param action)

	# "Undo last change": snapshot BOTH engines before an impactful toggle so the user can revert a
	# change that silently broke something (the per-action health rollback only catches a dead daemon).
	# Kept to the high-impact switches — not per-domain edits, which would flood the ring.
	# nosnap=1 lets a multi-step UI action (e.g. a hybrid preset = geosite + list) skip the 2nd+ snapshot,
	# so one user click produces ONE undo point (the first sub-action already captured the pre-click state)
	case "$action" in
		z2strat|z2quic|z2ipv6|z2autotoggle|mssclamp|devicesapply)
			[ "$(get_param nosnap)" = 1 ] || undo_push "$action" ;;
	esac

	case "$action" in
	add)
		rtype=$(get_param type)
		case "$rtype" in DOMAIN-SUFFIX|DOMAIN|DOMAIN-KEYWORD|GEOSITE|IP-CIDR|GEOIP) ;; *) rtype=DOMAIN-SUFFIX ;; esac
		rnode=$(get_param node)
		case "$rnode" in PROXY|DIRECT|REJECT|"$EXIT_GROUP") ;; *) rnode=PROXY ;; esac
		case "$rtype" in
			GEOSITE)        val=$(printf '%s' "$(get_param domain)" | tr 'A-Z' 'a-z' | sed 's/[^a-z0-9._!-]//g') ;;
			GEOIP)          val=$(printf '%s' "$(get_param domain)" | tr 'A-Z' 'a-z' | sed 's/[^a-z0-9-]//g') ;;
			DOMAIN-KEYWORD) val=$(printf '%s' "$(get_param domain)" | tr 'A-Z' 'a-z' | sed 's/[^a-z0-9.*-]//g') ;;
			IP-CIDR)        val=$(clean_ip "$(get_param domain)")
			                case "$val" in */*) ;; *) val="$val/32" ;; esac
			                case "$val" in *.*/*|*:*/*) ;; *) val="" ;; esac ;;
			*)              val=$(printf '%s' "$(get_param domain)" | parse_domains | head -1) ;;
		esac
		[ -z "$val" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		# GEOIP rules need GeoIP.dat loaded, else mihomo won't start — refuse until GeoIP is enabled.
		[ "$rtype" = GEOIP ] && ! geoip_ready && { json_header; printf '{"ok":false,"error":"geoip_off"}'; exit 0; }
		if [ "$(rule_exists "$rtype" "$val")" = 1 ]; then
			json_header; printf '{"ok":true,"dup":true}'; exit 0
		fi
		add_rule "$rtype" "$val" "$rnode"; uci commit nikki; apply_nikki
		# a bad geoip code can break the config — revert if mihomo went down
		if [ "$rtype" = GEOIP ] && ! pgrep -f /usr/bin/mihomo >/dev/null; then
			delete_rule GEOIP "$val"; uci commit nikki; apply_nikki
			json_header; printf '{"ok":false,"error":"rejected (reverted)"}'; exit 0
		fi
		json_header; printf '{"ok":true}'; exit 0

		;;
	addbulk)
		tmp="/tmp/nikki_add.$$"
		printf '%s' "$(get_param domains)" | parse_domains > "$tmp"
		added=0; dup=0
		while IFS= read -r d; do
			[ -z "$d" ] && continue
			if [ "$(domain_exists "$d")" = 1 ]; then dup=$((dup + 1)); continue; fi
			add_domain "$d"; added=$((added + 1))
		done < "$tmp"
		rm -f "$tmp"
		[ "$added" -gt 0 ] && { uci commit nikki; apply_nikki; }
		json_header; printf '{"ok":true,"added":%d,"dup":%d}' "$added" "$dup"; exit 0

		;;
	delbulk)
		tmp="/tmp/nikki_del.$$"
		printf '%s' "$(get_param domains)" | parse_domains > "$tmp"
		removed=0
		while IFS= read -r d; do
			[ -z "$d" ] && continue
			if [ "$(domain_exists "$d")" = 1 ]; then delete_domain "$d"; removed=$((removed + 1)); fi
		done < "$tmp"
		rm -f "$tmp"
		[ "$removed" -gt 0 ] && { uci commit nikki; apply_nikki; }
		json_header; printf '{"ok":true,"removed":%d}' "$removed"; exit 0

		;;
	setall)
		want="/tmp/nikki_want.$$"; cur="/tmp/nikki_cur.$$"
		printf '%s' "$(get_param domains)" | parse_domains > "$want"
		i=0
		while uci -q get "nikki.@rule[$i]" >/dev/null 2>&1; do
			[ "$(uci -q get "nikki.@rule[$i].type")" = "$TYPE_DEFAULT" ] \
				&& [ "$(uci -q get "nikki.@rule[$i].node")" = "$NODE_DEFAULT" ] \
				&& uci -q get "nikki.@rule[$i].matcher"
			i=$((i + 1))
		done > "$cur"
		removed=0; added=0
		while IFS= read -r m; do
			[ -z "$m" ] && continue
			grep -qxF "$m" "$want" || { delete_domain "$m"; removed=$((removed + 1)); }
		done < "$cur"
		while IFS= read -r d; do
			[ -z "$d" ] && continue
			[ "$(domain_exists "$d")" = 1 ] || { add_domain "$d"; added=$((added + 1)); }
		done < "$want"
		rm -f "$want" "$cur"
		[ $((removed + added)) -gt 0 ] && { uci commit nikki; apply_nikki; }
		json_header; printf '{"ok":true,"added":%d,"removed":%d}' "$added" "$removed"; exit 0

		;;
	del)
		idx=$(get_param idx | sed 's/[^0-9]//g')
		[ -z "$idx" ] && { json_header; printf '{"ok":false,"error":"bad idx"}'; exit 0; }
		uci delete "nikki.@rule[$idx]" 2>/dev/null
		uci commit nikki; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

		;;
	ruledelbulk)
		# delete several rules in ONE commit; indexes must be processed descending —
		# uci reindexes anonymous sections on delete, ascending order would shift targets
		idxs=$(get_param idxs | tr -c '0-9' ' ' | tr ' ' '\n' | grep . | sort -rn | uniq)
		[ -z "$idxs" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		n=0
		for i in $idxs; do uci delete "nikki.@rule[$i]" 2>/dev/null && n=$((n + 1)); done
		uci commit nikki; apply_nikki
		json_header; printf '{"ok":true,"removed":%d}' "$n"; exit 0

		;;
	toggle)
		idx=$(get_param idx | sed 's/[^0-9]//g')
		cur=$(uci -q get "nikki.@rule[$idx].enabled"); [ -z "$cur" ] && cur=1
		[ "$cur" = 1 ] && new=0 || new=1
		uci set "nikki.@rule[$idx].enabled=$new"
		uci commit nikki; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

		;;
	ruledit)
		idx=$(get_param idx | sed 's/[^0-9]//g')
		[ -z "$idx" ] && { json_header; printf '{"ok":false,"error":"bad idx"}'; exit 0; }
		uci -q get "nikki.@rule[$idx]" >/dev/null 2>&1 || { json_header; printf '{"ok":false,"error":"no rule"}'; exit 0; }
		oldt=$(uci -q get "nikki.@rule[$idx].type"); oldn=$(uci -q get "nikki.@rule[$idx].node")
		ntype=$(get_param type); case "$ntype" in DOMAIN-SUFFIX|DOMAIN|DOMAIN-KEYWORD|GEOSITE|IP-CIDR|GEOIP) uci set "nikki.@rule[$idx].type=$ntype" ;; esac
		nnode=$(get_param node); case "$nnode" in PROXY|DIRECT|REJECT|"$EXIT_GROUP") uci set "nikki.@rule[$idx].node=$nnode" ;; esac
		uci commit nikki; apply_nikki; sleep 3
		if ! pgrep -f /usr/bin/mihomo >/dev/null; then
			# a bad combo (e.g. IP-CIDR with a domain value) can break the config — revert
			uci set "nikki.@rule[$idx].type=$oldt"; uci set "nikki.@rule[$idx].node=$oldn"; uci commit nikki; apply_nikki
			json_header; printf '{"ok":false,"error":"rejected (reverted)"}'; exit 0
		fi
		json_header; printf '{"ok":true}'; exit 0

		;;
	svc)
		op=$(get_param op)
		case "$op" in
			start|stop|restart|reload|enable|disable) /etc/init.d/nikki "$op" >/dev/null 2>&1 ;;
			*) json_header; printf '{"ok":false,"error":"bad op"}'; exit 0 ;;
		esac
		case "$op" in start|stop|restart) sleep 3 ;; esac
		running=0; pgrep -f /usr/bin/mihomo >/dev/null 2>&1 && running=1
		booten=0; /etc/init.d/nikki enabled 2>/dev/null && booten=1
		json_header; printf '{"ok":true,"running":%d,"boot":%d}' "$running" "$booten"; exit 0

		;;
	update)
		update_start "$(get_param op)"; rc=$?
		json_header
		case "$rc" in
			0) printf '{"ok":true,"started":true}' ;;
			1) printf '{"ok":false,"error":"busy"}' ;;
			3) printf '{"ok":false,"error":"no space left (/tmp or geo dir)"}' ;;
			*) printf '{"ok":false,"error":"bad op"}' ;;
		esac
		exit 0

		;;
	undo)
		# restore a pre-change snapshot. Jumping back to point N means every CHANGE since then is undone,
		# so drop the chosen snapshot AND all newer ones (filenames are epoch seconds → numerically newer).
		id=$(get_param id | tr -cd '0-9')
		[ -n "$id" ] && [ -f "$UNDO_DIR/$id.tgz" ] || id=$(_undo_ids | head -1)
		f="$UNDO_DIR/$id.tgz"
		[ -n "$id" ] && [ -f "$f" ] || { json_header; printf '{"ok":false,"error":"nothing to undo"}'; exit 0; }
		snap_build "$REDO_FILE" redo >/dev/null 2>&1   # capture current state so this undo can be redone
		snap_restore "$f"; rc=$?
		for _u in "$UNDO_DIR"/*.tgz; do
			[ -f "$_u" ] || continue
			[ "$(basename "$_u" .tgz)" -ge "$id" ] 2>/dev/null && rm -f "$_u"
		done
		json_header
		case "$rc" in
			0) printf '{"ok":true}' ;;
			2) printf '{"ok":false,"error":"restore broke a service (reverted)"}' ;;
			*) printf '{"ok":false,"error":"restore had problems (code %s)"}' "$rc" ;;
		esac
		exit 0

		;;
	redo)
		# re-apply the state captured just before the last undo ("undo the undo")
		[ -f "$REDO_FILE" ] || { json_header; printf '{"ok":false,"error":"nothing to redo"}'; exit 0; }
		snap_restore "$REDO_FILE"; rc=$?
		rm -f "$REDO_FILE"
		json_header
		case "$rc" in
			0) printf '{"ok":true}' ;;
			2) printf '{"ok":false,"error":"restore broke a service (reverted)"}' ;;
			*) printf '{"ok":false,"error":"restore had problems (code %s)"}' "$rc" ;;
		esac
		exit 0

		;;
	bkrestore)
		# one-click restore of a rotating auto-backup (daily/weekly/monthly)
		which=$(get_param which | tr -cd 'a-z')
		case "$which" in daily|weekly|monthly) ;; *) json_header; printf '{"ok":false,"error":"bad name"}'; exit 0 ;; esac
		[ -f "$BACKUP_DIR/$which.tar.gz" ] || { json_header; printf '{"ok":false,"error":"no such backup"}'; exit 0; }
		snap_restore "$BACKUP_DIR/$which.tar.gz"; rc=$?
		json_header
		case "$rc" in
			0) printf '{"ok":true}' ;;
			2) printf '{"ok":false,"error":"restore broke a service (reverted)"}' ;;
			*) printf '{"ok":false,"error":"restore had problems (code %s)"}' "$rc" ;;
		esac
		exit 0

		;;
	z2bkrestore)
		# one-click restore of a rotating zapret2-only auto-backup (z2-daily/weekly/monthly)
		which=$(get_param which | tr -cd 'a-z')
		case "$which" in daily|weekly|monthly) ;; *) json_header; printf '{"ok":false,"error":"bad name"}'; exit 0 ;; esac
		[ -f "$BACKUP_DIR/z2-$which.tar.gz" ] || { json_header; printf '{"ok":false,"error":"no such backup"}'; exit 0; }
		rd="/tmp/nu-z2rrst.$$"; rm -rf "$rd"; mkdir -p "$rd"
		tar -xzf "$BACKUP_DIR/z2-$which.tar.gz" -C "$rd" 2>/dev/null
		z2_restore_backup "$rd"; rc=$?
		rm -rf "$rd"
		json_header
		case "$rc" in
			0) printf '{"ok":true}' ;;
			2) printf '{"ok":false,"error":"restore broke zapret2 (reverted)"}' ;;
			*) printf '{"ok":false,"error":"restore failed (code %s)"}' "$rc" ;;
		esac
		exit 0

		;;
	ipadd)
		ip=$(clean_ip "$(get_param ip)")
		[ -z "$ip" ] && { json_header; printf '{"ok":false,"error":"empty ip"}'; exit 0; }
		case "$ip" in */*) ;; *:*) ;; *) ip="$ip/32" ;; esac
		case "$ip" in *.*|*:*) ;; *) json_header; printf '{"ok":false,"error":"bad ip"}'; exit 0 ;; esac
		for e in $(uci -q get nikki.proxy.reserved_ip); do
			[ "$e" = "$ip" ] && { json_header; printf '{"ok":true,"dup":true}'; exit 0; }
		done
		uci add_list "nikki.proxy.reserved_ip=$ip"; uci commit nikki; apply_nikki
		json_header; printf '{"ok":true,"ip":"%s"}' "$ip"; exit 0

		;;
	ipdel)
		ip=$(clean_ip "$(get_param ip)")
		if [ "$(ip_is_default "$ip")" = 1 ] || node_ips | grep -qxF "$ip"; then
			json_header; printf '{"ok":false,"error":"protected"}'; exit 0   # default range or a VPN-node IP
		fi
		uci del_list "nikki.proxy.reserved_ip=$ip"; uci commit nikki; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

		;;
	devicesapply)
		# One request commits everything on the merged devices tab at once (both modes, both engines'
		# full checkbox state) — the panel builds one working copy client-side and sends it as a whole,
		# rather than a call per checkbox toggle.
		nmode=$(get_param nikkiMode); case "$nmode" in exclude|only) ;; *) nmode=exclude ;; esac
		zmode=$(get_param z2Mode); case "$zmode" in exclude|only) ;; *) zmode=exclude ;; esac
		nlist=""; for m in $(printf '%s' "$(get_param nikkiMacs)" | tr ',' ' '); do
			m=$(clean_mac "$m"); valid_mac "$m" || continue
			case " $nlist " in *" $m "*) ;; *) nlist="$nlist $m" ;; esac
		done
		zlist=""; for m in $(printf '%s' "$(get_param z2Macs)" | tr ',' ' '); do
			m=$(clean_mac "$m"); valid_mac "$m" || continue
			case " $zlist " in *" $m "*) ;; *) zlist="$zlist $m" ;; esac
		done
		if nikki_present; then
			uci set "nikki-unblock.config.nikki_device_mode=$nmode"; uci commit nikki-unblock
			nikki_acl_rebuild "$nlist"
			nikki_acl_apply_mode "$nmode"
			nikki_acl_fix_order
			uci commit nikki; apply_nikki
		fi
		if zapret2_present; then
			uci -q delete nikki-unblock.config.z2_bypass_mac 2>/dev/null
			for m in $zlist; do uci add_list "nikki-unblock.config.z2_bypass_mac=$m"; done
			uci set "nikki-unblock.config.z2_device_mode=$zmode"
			uci commit nikki-unblock
			z2_bypass_write_hook; z2_bypass_apply
		fi
		json_header; printf '{"ok":true}'; exit 0

		;;
	z2svc)
		op=$(get_param op)
		case "$op" in
			# On OpenWrt fw4 a bare `start` brings up nfqws2 but does NOT rebuild the desync nft rules
			# (they come from the firewall include, applied on a full restart / fw reload) — so the
			# service reads "running" yet nothing is bypassed. Use `restart` for the on-toggle so the
			# firewall is actually (re)built. Any "should be running" op clears the user-stop marker so
			# the watchdog resumes healing; `stop` sets it so the watchdog leaves a deliberate stop alone.
			start) rm -f "$Z2_USERSTOP"; /etc/init.d/zapret2 restart >/dev/null 2>&1 ;;
			restart|reload) rm -f "$Z2_USERSTOP"; /etc/init.d/zapret2 "$op" >/dev/null 2>&1 ;;
			stop) touch "$Z2_USERSTOP"; /etc/init.d/zapret2 stop >/dev/null 2>&1 ;;
			enable|disable) /etc/init.d/zapret2 "$op" >/dev/null 2>&1 ;;
			*) json_header; printf '{"ok":false,"error":"bad op"}'; exit 0 ;;
		esac
		case "$op" in start|stop|restart|reload) sleep 2 ;; esac
		rn=0; z2_running && rn=1; bt=0; /etc/init.d/zapret2 enabled 2>/dev/null && bt=1
		json_header; printf '{"ok":true,"running":%d,"boot":%d}' "$rn" "$bt"; exit 0

		;;
	z2strat)
		# switch the curated DPI-bypass strategy (rewrites NFQWS2_OPT) with backup + health rollback
		id=$(printf '%s' "$(get_param id)" | tr -cd 'a-z0-9_-')
		body=$(z2_strat_body "$id")
		[ -z "$body" ] && { json_header; printf '{"ok":false,"error":"bad strategy"}'; exit 0; }
		[ -f "$Z2_CONFIG" ] || { json_header; printf '{"ok":false,"error":"no config"}'; exit 0; }
		was=0; z2_running && was=1
		cp "$Z2_CONFIG" "$Z2_CONFIG.strat.bak"
		printf '%s' "$body" | z2_write_opt
		/etc/init.d/zapret2 restart >/dev/null 2>&1; sleep 4
		if z2_running && { [ "$was" = 0 ] || z2_desync_ok; }; then
			rm -f "$Z2_CONFIG.strat.bak"
			json_header; printf '{"ok":true,"strategy":"%s"}' "$id"; exit 0
		fi
		# strategy broke the daemon / desync — revert
		mv "$Z2_CONFIG.strat.bak" "$Z2_CONFIG"
		/etc/init.d/zapret2 restart >/dev/null 2>&1
		json_header; printf '{"ok":false,"error":"rejected (reverted)"}'; exit 0

		;;
	z2quic)
		on=$(get_param on | tr -cd '01' | cut -c1)
		quicblock_set "$on"
		q=0; quicblock_on && q=1
		json_header; printf '{"ok":true,"quic_block":%d}' "$q"; exit 0

		;;
	z2ipv6)
		on=$(get_param on | tr -cd '01' | cut -c1)   # on=1 → DISABLE ipv6
		ipv6_set "$on"
		v=0; ipv6_off && v=1
		json_header; printf '{"ok":true,"ipv6_off":%d}' "$v"; exit 0

		;;
	z2hostadd)
		d=$(printf '%s' "$(get_param domain)" | parse_domains | head -1)
		[ -z "$d" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		touch "$Z2_USER"
		if grep -qxF "$d" "$Z2_USER" 2>/dev/null; then json_header; printf '{"ok":true,"dup":true}'; exit 0; fi
		echo "$d" >> "$Z2_USER"; z2_apply_hosts
		json_header; printf '{"ok":true}'; exit 0

		;;
	z2hostdel)
		d=$(printf '%s' "$(get_param domain)" | parse_domains | head -1)
		if [ -n "$d" ] && [ -f "$Z2_USER" ]; then
			grep -vxF "$d" "$Z2_USER" > "$Z2_USER.tmp" 2>/dev/null; mv "$Z2_USER.tmp" "$Z2_USER"; z2_apply_hosts
		fi
		json_header; printf '{"ok":true}'; exit 0

		;;
	z2hostdelbulk)
		ds=$(printf '%s' "$(get_param domains)" | parse_domains)
		[ -z "$ds" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		if [ -f "$Z2_USER" ]; then
			cp "$Z2_USER" "$Z2_USER.tmp"
			for d in $ds; do
				grep -vxF "$d" "$Z2_USER.tmp" > "$Z2_USER.tmp2" 2>/dev/null; mv "$Z2_USER.tmp2" "$Z2_USER.tmp"
			done
			mv "$Z2_USER.tmp" "$Z2_USER"; z2_apply_hosts
		fi
		json_header; printf '{"ok":true}'; exit 0

		;;
	z2preset_apply)
		# atomic on/off of a z2 preset, run DETACHED and tracked in $Z2_PRESET_OP (poll ?api=z2presetop)
		id=$(printf '%s' "$(get_param id)" | tr -cd 'a-z0-9_-')   # sanitised: no slashes/dots → no path escape
		[ -z "$id" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		# busy while another z2-preset apply runs, or while an update swaps the zapret2 binaries
		{ op_busy "$Z2_PRESET_OP" || upd_running; } && { json_header; printf '{"ok":false,"error":"busy"}'; exit 0; }
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		pname=$(get_param name)
		undo_push z2preset   # ONE undo point for the whole apply
		op_start "$Z2_PRESET_OP" "$id" "$pname" "$on" _z2presetapply "$id" "$on" "$pname"
		json_header; printf '{"ok":true,"started":true}'; exit 0

		;;
	z2exclude|z2excludebulk)
		if [ "$action" = "z2exclude" ]; then
			ds=$(printf '%s' "$(get_param domain)" | parse_domains | head -1)
		else
			ds=$(printf '%s' "$(get_param domains)" | parse_domains)
		fi
		[ -z "$ds" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		z2_exclude_domains "$ds"
		json_header; printf '{"ok":true}'; exit 0

		;;
	z2unexclude)
		# single-domain form reports "protected" honestly (the bulk form just skips those)
		d=$(printf '%s' "$(get_param domain)" | parse_domains | head -1)
		if [ -n "$d" ] && z2_node_hosts | grep -qxF "$d"; then
			json_header; printf '{"ok":false,"error":"protected"}'; exit 0
		fi
		[ -n "$d" ] && z2_unexclude_domains "$d"
		json_header; printf '{"ok":true}'; exit 0

		;;
	z2unexcludebulk)
		ds=$(printf '%s' "$(get_param domains)" | parse_domains)
		[ -z "$ds" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		z2_unexclude_domains "$ds"
		json_header; printf '{"ok":true}'; exit 0

		;;
	z2autoclear)
		: > "$Z2_AUTO" 2>/dev/null; /etc/init.d/zapret2 reload >/dev/null 2>&1
		json_header; printf '{"ok":true}'; exit 0

		;;
	z2autoprune)
		# drop auto-learned domains already covered (exact or by suffix) by the manual OR preset lists —
		# e.g. once googlevideo.com is a manual/preset entry, all the learned rrX.googlevideo.com are redundant
		before=$(z2_count "$Z2_AUTO")
		cov=$(cat "$Z2_USER" "$Z2_MAIN" 2>/dev/null | sed 's/\r$//; s/[[:space:]]//g' | grep -vE '^($|#)' | tr 'A-Z' 'a-z' | sort -u)
		if [ -n "$cov" ] && [ -f "$Z2_AUTO" ]; then
			cp "$Z2_AUTO" "$Z2_AUTO.prune"
			for s in $cov; do
				re=$(printf '%s' "$s" | sed 's/\./\\./g')
				grep -viE "(^|\.)$re\$" "$Z2_AUTO.prune" > "$Z2_AUTO.prune2" 2>/dev/null
				mv "$Z2_AUTO.prune2" "$Z2_AUTO.prune"
			done
			mv "$Z2_AUTO.prune" "$Z2_AUTO"
			/etc/init.d/zapret2 reload >/dev/null 2>&1
		fi
		after=$(z2_count "$Z2_AUTO")
		json_header; printf '{"ok":true,"removed":%d,"kept":%s}' "$((before - after))" "$after"; exit 0

		;;
	z2setup)
		# first-run curated default: switch a FRESH zapret2 to static curated presets instead of the flaky
		# autohostlist (it learns per-host, so every new googlevideo CDN fails on first contact). Guarded —
		# runs once (setup_done flag) and only when the user hasn't configured zapret2 yet, so a real setup
		# is never clobbered. On failure (e.g. applist unreachable) the flag stays UNSET → retried next time.
		uci -q get nikki-unblock.z2 >/dev/null 2>&1 || uci set nikki-unblock.z2=z2
		if [ "$(uci -q get nikki-unblock.z2.setup_done 2>/dev/null)" = 1 ] || ! zapret2_present; then
			json_header; printf '{"ok":true,"applied":0}'; exit 0
		fi
		applied=0; fresh=0
		# "fresh" = no manual domains, no presets AND a near-empty autolist. The autolist check matters:
		# a user who has been running autohostlist has hundreds of learned domains — force-disabling it
		# would drop their working sites. Those keep autohostlist; only genuinely-new installs get curated.
		if [ "$(z2_count "$Z2_USER")" = 0 ] && [ -z "$(z2_active_presets)" ] && [ "$(z2_count "$Z2_AUTO")" -lt 20 ]; then
			fresh=1
			mkdir -p "$Z2_PDIR"
			for id in youtube discord; do
				applist_domains "z2/$id" > "$Z2_PDIR/$id.lst.tmp" 2>/dev/null
				if [ -s "$Z2_PDIR/$id.lst.tmp" ]; then
					mv "$Z2_PDIR/$id.lst.tmp" "$Z2_PDIR/$id.lst"
					uci add_list nikki-unblock.z2.preset="$id"
					applied=1
				else rm -f "$Z2_PDIR/$id.lst.tmp"; fi
			done
			if [ "$applied" = 1 ]; then
				uci commit nikki-unblock
				# turn autohostlist OFF first so the single rebuild-restart applies both
				if [ -f "$Z2_CONFIG" ] && z2_autohostlist; then
					cp "$Z2_CONFIG" "$Z2_CONFIG.nipret.bak" 2>/dev/null
					sed -i "s/^\([[:space:]]*MODE_FILTER=\).*/\1hostlist/" "$Z2_CONFIG"
				fi
				z2_rebuild_main   # writes the preset hostlist + restarts (applies new main + autohostlist-off)
			fi
		fi
		# burn the once-flag only if we actually applied, or there was nothing to do (already configured) —
		# a fresh install whose applist fetch failed keeps the flag UNSET so it retries next time.
		if [ "$fresh" = 0 ] || [ "$applied" = 1 ]; then uci set nikki-unblock.z2.setup_done=1; uci commit nikki-unblock; fi
		json_header; printf '{"ok":true,"applied":%d}' "$applied"; exit 0

		;;
	z2autotoggle)
		on=$(get_param on | sed 's/[^01]//g')
		[ -f "$Z2_CONFIG" ] || { json_header; printf '{"ok":false,"error":"no config"}'; exit 0; }
		cp "$Z2_CONFIG" "$Z2_CONFIG.nipret.bak" 2>/dev/null
		if [ "$on" = 1 ]; then _mf=autohostlist; else _mf=hostlist; fi
		sed -i "s/^\([[:space:]]*MODE_FILTER=\).*/\1$_mf/" "$Z2_CONFIG"
		/etc/init.d/zapret2 restart >/dev/null 2>&1
		json_header; printf '{"ok":true,"autohostlist":%s}' "$([ "$on" = 1 ] && echo 1 || echo 0)"; exit 0

		;;
	preset_apply)
		# atomic on/off of a whole nikki preset (geosite + list) run DETACHED, tracked in $PRESET_OP.
		# The client sends only id+on — the schema fields are resolved server-side (preset_fields).
		id=$(get_param id | sed 's/[^a-z0-9_-]//g')
		[ -z "$id" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		preset_busy && { json_header; printf '{"ok":false,"error":"busy"}'; exit 0; }
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		preset_fields "$id" || { json_header; printf '{"ok":false,"error":"unknown preset"}'; exit 0; }
		undo_push preset   # ONE undo point for the whole apply
		op_start "$PRESET_OP" "$id" "$PF_NAME" "$on" _presetapply "$id" "$on" "$PF_CAT" "$PF_GEOIP" "$PF_IPS" "$PF_NODE" "$PF_HASLIST" "$PF_NAME"
		json_header; printf '{"ok":true,"started":true}'; exit 0

		;;
	autosync)
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		iv=$(get_param interval | sed 's/[^0-9a-z]//g'); [ -z "$iv" ] && iv=6h
		autosync_set "$on" "$iv"
		json_header; printf '{"ok":true,"enabled":%s,"interval":"%s"}' "$([ "$on" = 1 ] && echo true || echo false)" "$iv"; exit 0

		;;
	setlang)
		lang=$(get_param lang | sed 's/[^a-z]//g'); case "$lang" in ru|en) ;; *) lang=ru ;; esac
		uci set nikki-unblock.config.lang="$lang" 2>/dev/null; uci commit nikki-unblock 2>/dev/null
		json_header; printf '{"ok":true,"lang":"%s"}' "$lang"; exit 0

		;;
	nodeadd)
		mkdir -p "$NODES_DIR" "$PROV_DIR"
		raw=$(get_param config | sed 's/\r//g')
		nm=$(get_param name)
		fl=$(printf '%s' "$raw" | grep -vE '^[[:space:]]*$' | head -1)
		err=""; kind=node; yaml=""; id=""; pid=""; subid=""
		case "$fl" in
		"[Interface]"*)
			WGCONF="/tmp/nu-wg.$$"; printf '%s\n' "$raw" > "$WGCONF"
			[ -z "$nm" ] && nm="wg-$(grep -iE '^Endpoint' "$WGCONF" | head -1 | sed 's/.*=//; s/[[:space:]]//g; s/:.*//; s/\./-/g')"
			[ "$(grep -ic '^Jc' "$WGCONF")" -ge 1 ] && nm=$(printf '%s' "$nm" | sed 's/^wg-/awg-/')
			yaml=$(wg_to_yaml "$nm"); rm -f "$WGCONF"
			;;
		vless://*|vmess://*|trojan://*|ss://*|hysteria2://*|hy2://*|tuic://*)
			[ -z "$nm" ] && { nm=$(printf '%s' "$fl" | sed 's/.*#//'); nm=$(urldec "$nm"); }
			[ -z "$nm" ] && nm="link-node"
			yaml=$(sharelink_to_yaml "$fl" "$nm") || err="unsupported link type"
			[ -z "$yaml" ] && [ -z "$err" ] && err="could not parse link"
			;;
		http://*|https://*)
			# Fetch the subscription ourselves. Two kinds:
			#  - v2ray/base64 (or plain) list of share-links -> convert each into an individual node
			#    (manageable/orderable; needed because clash-UA output is often empty, e.g. remnawave).
			#  - real clash YAML with proxies: -> keep as an auto-updating proxy-provider (as before).
			subbody=$(curl -s --max-time 20 "$fl" 2>/dev/null)
			subdec=$(printf '%s' "$subbody" | b64d)
			if printf '%s\n%s\n' "$subdec" "$subbody" | grep -qiE '^(vless|vmess|trojan|ss|hysteria2|hy2|tuic)://'; then
				kind=multi; [ -z "$nm" ] && nm="sub"   # tracked link-subscription -> individual nodes (sub_sync)
			elif printf '%s' "$subbody" | grep -q 'proxies:'; then
				kind=provider; [ -z "$nm" ] && nm="sub-$(date +%s)"; pid=$(san_name "$nm")
				{ echo "  $pid:"; echo "    type: http"; echo "    url: $fl"; echo "    interval: 86400"
				  echo "    health-check: {enable: true, url: http://cp.cloudflare.com/generate_204, interval: 300}"; } > "$PROV_DIR/$pid.yaml"
			else
				err="subscription returned no usable nodes"
			fi
			;;
		*)
			# raw clash/mihomo proxy: a mapping or a "- name:" item. Normalize to a 1-item seq at
			# 2-space list indent via yq (robust to the pasted indentation), then reindent under nikki-proxies.
			_rf="/tmp/nu-raw.$$"; printf '%s\n' "$raw" > "$_rf"
			yaml=$(yq -M -o=yaml '[ (.[0] // .) ]' "$_rf" 2>/dev/null | sed 's/^/  /')
			rm -f "$_rf"
			case "$yaml" in *name:*) ;; *) err="need a valid clash proxy (a mapping or '- name:' item)"; yaml="" ;; esac
			[ -z "$nm" ] && nm=$(printf '%s' "$yaml" | grep -m1 'name:' | sed 's/.*name:[[:space:]]*//; s/[",]//g')
			;;
		esac
		[ -n "$err" ] && { json_header; printf '{"ok":false,"error":"%s"}' "$err"; exit 0; }
		multiids=""
		if [ "$kind" = node ]; then
			# ensure a unique proxy name — mihomo rejects a name that collides with the profile or another node
			b="$nm"; k=1
			while [ "$k" -lt 30 ] && name_taken "$nm"; do k=$((k+1)); nm="$b-$k"; done
			[ "$nm" = "$b" ] || yaml=$(printf '%s\n' "$yaml" | awk -v n="$nm" 'BEGIN{d=0} /name:/&&!d{sub(/name:.*/,"name: " n);d=1} {print}')
			id=$(san_name "$nm"); [ -z "$id" ] && id="node-$(date +%s)"
			printf '%s\n' "$yaml" > "$NODES_DIR/$id.yaml"
		elif [ "$kind" = multi ]; then
			# a tracked link-subscription: create its record + import nodes via sub_sync (refreshable later)
			mkdir -p "$SUBS_DIR"
			subid=$(san_name "$nm"); [ -z "$subid" ] && subid="sub-$(date +%s)"
			# avoid clobbering an existing sub of the same name
			[ -f "$SUBS_DIR/$subid.conf" ] && subid="$subid-$(date +%s)"
			{ printf 'url=%s\n' "$fl"; printf 'name=%s\n' "$nm"; } > "$SUBS_DIR/$subid.conf"
			if ! sub_sync "$subid" "$fl" "$nm"; then
				rm -f "$SUBS_DIR/$subid.conf"; json_header; printf '{"ok":false,"error":"no links could be parsed"}'; exit 0
			fi
			added=$(sub_owned_ids "$subid" | grep -c .)
			multiids=$(sub_owned_ids "$subid" | tr '\n' ' ')
			# auto-refresh is on by default — make sure the cron exists now that a subscription exists
			if subauto_on; then
				_siv=$(uci -q get nikki-unblock.config.subauto_interval 2>/dev/null); [ -z "$_siv" ] && _siv=24h
				subauto_set 1 "$_siv"
			fi
		fi
		protect_all_nodes   # shield the new node's server from zapret2 + add it to nikki's loop bypass
		regen_mixin; apply_nikki; sleep 6
		if ! pgrep -f /usr/bin/mihomo >/dev/null; then
			# config broke nikki -> roll back and report
			rm -f "$NODES_DIR/$id.yaml" "$PROV_DIR/$pid.yaml"
			for x in $multiids; do rm -f "$NODES_DIR/$x.yaml" "$NODES_DIR/$x.src"; done
			[ -n "$subid" ] && rm -f "$SUBS_DIR/$subid.conf"
			regen_mixin; apply_nikki
			json_header; printf '{"ok":false,"error":"config rejected by mihomo (reverted)"}'; exit 0
		fi
		if [ "$kind" = node ]; then
			rn=$(grep -m1 'name:' "$NODES_DIR/$id.yaml" | sed 's/.*name:[[:space:]]*//')
			json_header; printf '{"ok":true,"kind":"node","id":"%s","name":"%s","delay":"%s"}' "$id" "$rn" "$(mihomo_delay "$rn")"; exit 0
		elif [ "$kind" = multi ]; then
			json_header; printf '{"ok":true,"kind":"multi","added":%d}' "$added"; exit 0
		fi
		json_header; printf '{"ok":true,"kind":"provider","id":"%s"}' "$pid"; exit 0

		;;
	nodedel)
		id=$(get_param id | sed 's/[^a-z0-9_-]//g')
		if [ -n "$id" ]; then
			nm=$(grep -m1 'name:' "$NODES_DIR/$id.yaml" 2>/dev/null | sed 's/.*name:[[:space:]]*//')
			rm -f "$NODES_DIR/$id.yaml" "$NODES_DIR/$id.off" "$NODES_DIR/$id.src" "$PROV_DIR/$id.yaml"
			# drop the name from the order/off lists too
			for L in "$ORDER_FILE" "$OFF_FILE"; do
				[ -n "$nm" ] && [ -f "$L" ] && { grep -vxF "$nm" "$L" > "$L.tmp" 2>/dev/null; mv "$L.tmp" "$L"; }
			done
		fi
		regen_mixin; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

		;;
	nodecheck)
		id=$(get_param id | sed 's/[^a-z0-9_-]//g')
		rn=$(grep -m1 'name:' "$NODES_DIR/$id.yaml" 2>/dev/null | sed 's/.*name:[[:space:]]*//')
		# fall back to the raw name param (profile nodes aren't in our store) for a live probe
		[ -z "$rn" ] && rn=$(get_param name)
		[ -z "$rn" ] && { json_header; printf '{"ok":false,"error":"not found"}'; exit 0; }
		json_header; printf '{"ok":true,"delay":"%s"}' "$(mihomo_delay "$rn")"; exit 0

		;;
	nodetoggle)
		# toggle a node (profile OR ours) on/off by NAME via the shared off-list
		nm=$(get_param name)
		[ -z "$nm" ] && { json_header; printf '{"ok":false,"error":"no name"}'; exit 0; }
		touch "$OFF_FILE"
		if grep -qxF "$nm" "$OFF_FILE"; then
			grep -vxF "$nm" "$OFF_FILE" > "$OFF_FILE.tmp"; mv "$OFF_FILE.tmp" "$OFF_FILE"; en=1
		else
			printf '%s\n' "$nm" >> "$OFF_FILE"; en=0
		fi
		regen_mixin; apply_nikki; sleep 6
		if ! pgrep -f /usr/bin/mihomo >/dev/null; then
			if [ "$en" = 1 ]; then printf '%s\n' "$nm" >> "$OFF_FILE"; else grep -vxF "$nm" "$OFF_FILE" > "$OFF_FILE.tmp"; mv "$OFF_FILE.tmp" "$OFF_FILE"; fi
			regen_mixin; apply_nikki
			json_header; printf '{"ok":false,"error":"reload failed (reverted)"}'; exit 0
		fi
		json_header; printf '{"ok":true,"enabled":%s}' "$en"; exit 0

		;;
	nodeorder)
		# names = the full ordered list of exit node names, newline-separated
		get_param names | sed 's/[[:space:]]*$//' | awk 'NF' > "$ORDER_FILE"
		regen_mixin; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

		;;
	nodemode)
		m=$(get_param mode | sed 's/[^a-z-]//g'); case "$m" in urltest|fallback) ;; *) m=fallback ;; esac
		uci set nikki-unblock.config.node_mode="$m" 2>/dev/null; uci commit nikki-unblock 2>/dev/null
		regen_mixin; apply_nikki; sleep 3
		pgrep -f /usr/bin/mihomo >/dev/null || apply_nikki
		json_header; printf '{"ok":true,"mode":"%s"}' "$m"; exit 0

		;;
	migraterules)
		# move all "→ VPN" rules from the raw profile group ($BASE_GROUP) onto the managed exit group
		regen_mixin   # make sure UNBLOCK exists before rules point at it
		i=0; changed=0
		while uci -q get "nikki.@rule[$i]" >/dev/null 2>&1; do
			[ "$(uci -q get "nikki.@rule[$i].node")" = "$BASE_GROUP" ] && { uci set "nikki.@rule[$i].node=$EXIT_GROUP"; changed=$((changed + 1)); }
			i=$((i + 1))
		done
		[ "$changed" -gt 0 ] && uci commit nikki
		apply_nikki; sleep 4
		pgrep -f /usr/bin/mihomo >/dev/null || apply_nikki
		json_header; printf '{"ok":true,"changed":%d}' "$changed"; exit 0

		;;
	subrefresh)
		sid=$(get_param id | sed 's/[^a-z0-9_-]//g')
		[ -f "$SUBS_DIR/$sid.conf" ] || { json_header; printf '{"ok":false,"error":"no sub"}'; exit 0; }
		url=$(grep -m1 '^url=' "$SUBS_DIR/$sid.conf" | cut -d= -f2-); snm=$(grep -m1 '^name=' "$SUBS_DIR/$sid.conf" | cut -d= -f2-)
		BK="/tmp/nu-subbk.$$"; rm -rf "$BK"; mkdir -p "$BK"; cp "$NODES_DIR"/* "$BK/" 2>/dev/null
		if sub_sync "$sid" "$url" "$snm"; then
			protect_all_nodes   # protect any new node servers from zapret2 + nikki loop
			regen_mixin; apply_nikki; sleep 6
			if ! pgrep -f /usr/bin/mihomo >/dev/null; then
				rm -f "$NODES_DIR"/*.yaml "$NODES_DIR"/*.src 2>/dev/null; cp "$BK"/* "$NODES_DIR/" 2>/dev/null
				regen_mixin; apply_nikki; rm -rf "$BK"
				json_header; printf '{"ok":false,"error":"refresh broke mihomo (reverted)"}'; exit 0
			fi
			rm -rf "$BK"; json_header; printf '{"ok":true,"count":%d}' "$(sub_owned_ids "$sid" | grep -c .)"; exit 0
		fi
		rm -rf "$BK"; json_header; printf '{"ok":false,"error":"subscription empty/unreachable"}'; exit 0

		;;
	subdel)
		sid=$(get_param id | sed 's/[^a-z0-9_-]//g')
		for oid in $(sub_owned_ids "$sid"); do
			onm=$(node_name_of "$oid"); rm -f "$NODES_DIR/$oid.yaml" "$NODES_DIR/$oid.src"
			for L in "$ORDER_FILE" "$OFF_FILE"; do [ -f "$L" ] && [ -n "$onm" ] && { grep -vxF "$onm" "$L" > "$L.t" 2>/dev/null; mv "$L.t" "$L"; }; done
		done
		rm -f "$SUBS_DIR/$sid.conf"
		regen_mixin; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

		;;
	subauto)
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		iv=$(get_param interval | sed 's/[^0-9a-z]//g'); [ -z "$iv" ] && iv=24h
		subauto_set "$on" "$iv"
		json_header; printf '{"ok":true,"enabled":%s,"interval":"%s"}' "$([ "$on" = 1 ] && echo true || echo false)" "$iv"; exit 0

		;;
	backupauto)
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		backupauto_set "$on"
		[ "$on" = 1 ] && backup_auto_run   # write one immediately so there's something to restore
		json_header; printf '{"ok":true,"enabled":%s}' "$([ "$on" = 1 ] && echo true || echo false)"; exit 0

		;;
	z2backupauto)
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		zapret2_present || { json_header; printf '{"ok":false,"error":"no zapret2"}'; exit 0; }
		z2_backupauto_set "$on"
		[ "$on" = 1 ] && z2_backup_auto_run   # write one immediately so there's something to restore
		json_header; printf '{"ok":true,"enabled":%s}' "$([ "$on" = 1 ] && echo true || echo false)"; exit 0

		;;
	mssclamp)
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		mssclamp_set "$on"
		json_header; printf '{"ok":true,"enabled":%s}' "$([ "$on" = 1 ] && echo true || echo false)"; exit 0
		;;
	esac

	json_header; printf '{"ok":false,"error":"unknown action"}'; exit 0
fi

# ---- LAN device table (merged Nikki + Zapret2, by MAC) --------------------------------------
# One row per known device, cross-referenced against both engines' selection lists so the panel
# can render two independent checkboxes per device under a single "Общее → Устройства" tab.
devicesall_json() {
	json_header
	nk=0; nikki_present && nk=1
	z2=0; zapret2_present && z2=1
	_dt="/tmp/nu-devall.$$"; lan_devices_by_mac > "$_dt" 2>/dev/null
	nsel=" "; i=0
	while uci -q get "nikki.@lan_access_control[$i]" >/dev/null 2>&1; do
		m=$(uci -q get "nikki.@lan_access_control[$i].mac"); [ -n "$m" ] && nsel="$nsel$m "
		i=$((i + 1))
	done
	zsel=" "; for m in $(z2_bypass_macs); do zsel="$zsel$m "; done
	rows=""; seen=" "
	while IFS=$(printf '\t') read -r kmac kip knm; do
		seen="$seen$kmac "
		ns=false; case "$nsel" in *" $kmac "*) ns=true ;; esac
		zs=false; case "$zsel" in *" $kmac "*) zs=true ;; esac
		rows="$rows${rows:+,}{\"mac\":\"$(json_esc "$kmac")\",\"ip\":\"$(json_esc "$kip")\",\"name\":\"$(json_esc "$knm")\",\"nikki\":$ns,\"zapret2\":$zs}"
	done < "$_dt"
	# a selected MAC that dropped out of DHCP (stale lease / deleted static host) must still show up,
	# else it's stuck selected with no UI control left to clear it — counters tell the truth, so must the list
	for m in $nsel $zsel; do
		case "$seen" in *" $m "*) continue ;; esac
		seen="$seen$m "
		ns=false; case "$nsel" in *" $m "*) ns=true ;; esac
		zs=false; case "$zsel" in *" $m "*) zs=true ;; esac
		rows="$rows${rows:+,}{\"mac\":\"$(json_esc "$m")\",\"ip\":\"\",\"name\":\"\",\"nikki\":$ns,\"zapret2\":$zs}"
	done
	rm -f "$_dt"
	printf '{"nikki":{"present":%d,"mode":"%s"},"zapret2":{"present":%d,"mode":"%s"},"devices":[%s]}' \
		"$nk" "$(nikki_device_mode)" "$z2" "$(z2_device_mode)" "$rows"
}

[ "$API" = "list" ] && { list_json; exit 0; }
[ "$API" = "iplist" ] && { iplist_json; exit 0; }
[ "$API" = "devicesall" ] && { devicesall_json; exit 0; }
[ "$API" = "z2status" ] && { z2status_json; exit 0; }
[ "$API" = "ytdiag" ] && { ytdiag_json; exit 0; }
[ "$API" = "z2hosts" ] && { z2hosts_json; exit 0; }
[ "$API" = "z2presets" ] && { z2presets_json; exit 0; }
[ "$API" = "presets" ] && {
	json_header
	# `fresh=1` forces a rebuild (manual refresh after editing the applist).
	case "$QUERY_STRING" in *fresh=1*) rm -f "$PRESET_CACHE" "$IDX_CACHE" ;; esac
	# Serve the cache if it's younger than the TTL (cold build does index.json + N .lst curls ~7 s).
	if [ -f "$PRESET_CACHE" ]; then
		age=$(( $(date +%s) - $(date -r "$PRESET_CACHE" +%s 2>/dev/null || echo 0) ))
		[ "$age" -ge 0 ] && [ "$age" -lt "$PRESET_TTL" ] && { cat "$PRESET_CACHE"; exit 0; }
	fi
	body=$(presets_json)
	# Only cache a well-formed, non-empty array so a transient fetch failure can't pin an empty result.
	case "$body" in \[?*\]) printf '%s' "$body" > "$PRESET_CACHE" ;; esac
	printf '%s' "$body"
	exit 0
}
[ "$API" = "autosync" ] && { autosync_json; exit 0; }
[ "$API" = "versions" ] && { versions_json; exit 0; }
[ "$API" = "diag" ] && { diag_json; exit 0; }
[ "$API" = "updcheck" ] && { updcheck_json; exit 0; }
[ "$API" = "subauto" ] && { subauto_json; exit 0; }
[ "$API" = "backupauto" ] && { backupauto_json; exit 0; }
[ "$API" = "z2backupauto" ] && { z2_backupauto_json; exit 0; }
[ "$API" = "presetop" ] && { presetop_json; exit 0; }
[ "$API" = "z2presetop" ] && { op_json "$Z2_PRESET_OP"; exit 0; }
[ "$API" = "undolist" ] && { undolist_json; exit 0; }
[ "$API" = "updatestatus" ] && { updatestatus_json; exit 0; }
[ "$API" = "config" ] && { config_json; exit 0; }
[ "$API" = "nodes" ] && { nodes_json; exit 0; }
[ "$API" = "svcstatus" ] && {
	json_header
	running=0; pgrep -f /usr/bin/mihomo >/dev/null 2>&1 && running=1
	booten=0; /etc/init.d/nikki enabled 2>/dev/null && booten=1
	# Startup guard: does the configured base_group actually exist in mihomo? A wrong
	# base_group name (profile's proxy-group isn't "PROXY") makes every "→ VPN" rule point
	# at a nonexistent group. Only meaningful while running (down → /proxies won't answer).
	base_ok=1
	[ "$running" = 1 ] && { curl -s -m 5 -H "Authorization: Bearer $(mihomo_secret)" \
		"$MIHOMO_API/proxies/$(urlenc_all "$BASE_GROUP")" 2>/dev/null | grep -q '"name"' || base_ok=0; }
	mss=0; mssclamp_on && mss=1
	printf '{"running":%d,"boot":%d,"base_group":"%s","base_ok":%d,"mss":%d}' \
		"$running" "$booten" "$BASE_GROUP" "$base_ok" "$mss"; exit 0
}

# ---- HTML page -------------------------------------------------------------
# The UI lives in static files (/www/nikki-unblock/app.{html,css,js}) served by uhttpd; the CGI
# stays the entry-point URL and stamps @VER@ (app.js mtime) into the asset links, so browsers pick
# up fresh CSS/JS right after a self-update instead of a stale cache.
APP_DIR="/www/nikki-unblock"
printf 'Status: 200 OK\r\nContent-Type: text/html; charset=utf-8\r\nCache-Control: no-store\r\n\r\n'
_v=$(date -r "$APP_DIR/app.js" +%s 2>/dev/null); [ -z "$_v" ] && _v=0
sed "s/@VER@/$_v/g" "$APP_DIR/app.html"
