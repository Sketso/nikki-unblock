		rm -f "$Z2_PDIR/$id.lst"
		z2_rebuild_main
		json_header; printf '{"ok":true}'; exit 0

	elif [ "$action" = "z2exclude" ]; then
		# "don't bypass" an auto-learned domain: ban it (user-exclude, checked first so it's never
		# desynced) AND drop it from the auto list so it disappears and stays out.
		d=$(printf '%s' "$(get_param domain)" | parse_domains | head -1)
		[ -z "$d" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		touch "$Z2_HOSTX"; grep -qxF "$d" "$Z2_HOSTX" 2>/dev/null || echo "$d" >> "$Z2_HOSTX"
