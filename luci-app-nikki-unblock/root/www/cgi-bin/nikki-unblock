		# a user who has been running autohostlist has hundreds of learned domains — force-disabling it
		# would drop their working sites. Those keep autohostlist; only genuinely-new installs get curated.
		if [ "$(z2_count "$Z2_USER")" = 0 ] && [ -z "$(z2_active_presets)" ] && [ "$(z2_count "$Z2_AUTO")" -lt 20 ]; then
