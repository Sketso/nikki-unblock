		case "$rc" in
			0) printf '{"ok":true}' ;;
			2) printf '{"ok":false,"error":"restore broke a service (reverted)"}' ;;
			*) printf '{"ok":false,"error":"restore had problems (code %s)"}' "$rc" ;;
		esac
