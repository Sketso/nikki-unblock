    <div class="hint" id="modeHint"></div>
    <ul id="nodeList" class="nodelist"></ul>
    <button type="button" class="ghost" id="migrateBtn" data-i18n="migrateRules" style="margin-top:.4rem;font-size:.8rem"></button>

