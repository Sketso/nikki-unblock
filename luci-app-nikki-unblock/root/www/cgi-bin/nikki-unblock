        <option value="1h" data-i18n="iv1h"></option>
        <option value="6h" data-i18n="iv6h"></option>
        <option value="12h" data-i18n="iv12h"></option>
        <option value="24h" data-i18n="iv24h"></option>
        <option value="weekly" data-i18n="ivWeekly"></option>
      </select>
      <div class="hint" data-i18n="subAutoHint"></div>
    </div>
    <div class="msg" id="subMsg"></div>
  </section>

  <!-- ================= MANAGEMENT ================= -->
  <section class="view" id="view-mgmt">
    <div class="svc">
      <div class="swrow">
        <span class="swlabel"><span class="dot" id="svcDot"></span><span id="svcState">…</span></span>
        <label class="sw"><input type="checkbox" id="svcRun"><span class="sl"></span></label>
      </div>
      <div class="swrow">
        <span class="swlabel" data-i18n="svcBoot"></span>
        <label class="sw"><input type="checkbox" id="svcBootChk"><span class="sl"></span></label>
      </div>
      <div class="swrow">
        <span class="swlabel" data-i18n="mssLabel" data-i18n-title="mssHint"></span>
        <label class="sw"><input type="checkbox" id="mssChk"><span class="sl"></span></label>
      </div>
      <div class="hint" data-i18n="mssHint"></div>
      <div class="btns">
        <button type="button" class="ghost" id="svcRestart" data-i18n="svcRestart"></button>
        <button type="button" class="ghost" id="svcReload" data-i18n="svcReload"></button>
      </div>
      <div class="msg" id="svcMsg"></div>
    </div>

    <div class="svc upd">
      <h3 data-i18n="updTitle"></h3>
      <div class="uprow"><span class="upname">nikki-unblock</span><span class="upver" id="verSelf">…</span></div>
      <div class="uprow"><span class="upname">nikki + mihomo</span><span class="upver" id="verNikki">…</span></div>
      <div class="uprow"><span class="upname">GeoIP / GeoSite</span><span class="upver" id="verGeo">…</span></div>
      <div class="btns">
        <button type="button" class="ghost" id="updSelf" data-i18n="updSelf"></button>
        <button type="button" class="ghost" id="updNikki" data-i18n="updNikki"></button>
        <button type="button" class="ghost" id="updGeo" data-i18n="updGeo"></button>
        <button type="button" id="updAll" data-i18n="updAll"></button>
      </div>
      <pre class="uplog" id="updLog" hidden></pre>
      <div class="msg" id="updMsg"></div>
    </div>

    <div class="svc upd">
      <h3 data-i18n="bkTitle"></h3>
      <div class="btns">
        <button type="button" id="bkDownload" data-i18n="bkDownload"></button>
        <button type="button" class="ghost" id="bkRestoreBtn" data-i18n="bkRestore"></button>
        <input type="file" id="bkFile" accept=".gz,.tar.gz,application/gzip" hidden>
      </div>
      <div class="swrow">
        <span class="swlabel" data-i18n="bkAuto"></span>
        <label class="sw"><input type="checkbox" id="bkAutoOn"><span class="sl"></span></label>
      </div>
      <ul id="bkList" class="nodelist"></ul>
      <div class="hint" data-i18n="bkHint"></div>
      <div class="msg" id="bkMsg"></div>
    </div>
  </section>

  <!-- preset contents modal -->
  <div class="modal" id="pmodal" hidden>
    <div class="modal-card">
      <div class="modal-head"><span id="pmTitle"></span><button class="mclose" id="pmClose">✕</button></div>
      <div class="modal-body" id="pmBody"></div>
    </div>
  </div>

