                   ips: (p.ipcidr || []).join(","), node: p.node || EXITG,
                   haslist: (p.domains || []).length ? 1 : 0, name: p.name };
  let r = null; try { r = await api("preset_apply", params); } catch(e){}
  if (r && r.ok && r.started) ensurePresetPoll();
