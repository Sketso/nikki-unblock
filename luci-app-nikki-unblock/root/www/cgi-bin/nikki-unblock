			json_header; printf '{"ok":false,"error":"protected"}'; exit 0
		fi
		if [ -n "$d" ] && [ -f "$Z2_HOSTX" ]; then
			grep -vxF "$d" "$Z2_HOSTX" > "$Z2_HOSTX.tmp" 2>/dev/null; mv "$Z2_HOSTX.tmp" "$Z2_HOSTX"
			/etc/init.d/zapret2 reload >/dev/null 2>&1
		fi
		json_header; printf '{"ok":true}'; exit 0

	elif [ "$action" = "z2excludebulk" ]; then
