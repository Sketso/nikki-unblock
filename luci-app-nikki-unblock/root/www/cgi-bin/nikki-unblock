  geoList(p.geosite).forEach(c => h += '<div class="pmrow"><b>GEOSITE</b> · <code>' + escH(c) + '</code> → ' + tgt + '</div>');
  geoList(p.geoip).forEach(g => h += '<div class="pmrow"><b>GEOIP</b> · <code>' + escH(g) + '</code> → ' + tgt + (GEO_OK ? "" : " · " + t("geoOff")) + '</div>');
