		which=$(get_param which | tr -cd 'a-z')
		case "$which" in daily|weekly|monthly) ;; *) json_header; printf '{"ok":false,"error":"bad name"}'; exit 0 ;; esac
		[ -f "$BACKUP_DIR/$which.tar.gz" ] || { json_header; printf '{"ok":false,"error":"no such backup"}'; exit 0; }
