		touch "$Z2_HOSTX"
		for d in $ds; do
			grep -qxF "$d" "$Z2_HOSTX" 2>/dev/null || echo "$d" >> "$Z2_HOSTX"
			re=$(printf '%s' "$d" | sed 's/[.*]/\\&/g')
			[ -f "$Z2_AUTO" ] && { grep -viE "(^|\.)$re\$" "$Z2_AUTO" > "$Z2_AUTO.tmp" 2>/dev/null; mv "$Z2_AUTO.tmp" "$Z2_AUTO"; }
		done
		/etc/init.d/zapret2 reload >/dev/null 2>&1
		json_header; printf '{"ok":true}'; exit 0

	elif [ "$action" = "z2unexcludebulk" ]; then
		ds=$(printf '%s' "$(get_param domains)" | parse_domains)
		[ -z "$ds" ] && { json_header; printf '{"ok":false,"error":"empty"}'; exit 0; }
		if [ -f "$Z2_HOSTX" ]; then
			prot=$(z2_node_hosts)
			cp "$Z2_HOSTX" "$Z2_HOSTX.tmp"
			for d in $ds; do
				printf '%s\n' "$prot" | grep -qxF "$d" && continue   # never drop a VPN-node protection
				grep -vxF "$d" "$Z2_HOSTX.tmp" > "$Z2_HOSTX.tmp2" 2>/dev/null; mv "$Z2_HOSTX.tmp2" "$Z2_HOSTX.tmp"
			done
			mv "$Z2_HOSTX.tmp" "$Z2_HOSTX"
			/etc/init.d/zapret2 reload >/dev/null 2>&1
		fi
		json_header; printf '{"ok":true}'; exit 0

	elif [ "$action" = "z2autoclear" ]; then
		: > "$Z2_AUTO" 2>/dev/null; /etc/init.d/zapret2 reload >/dev/null 2>&1
		json_header; printf '{"ok":true}'; exit 0

	elif [ "$action" = "z2autoprune" ]; then
		# drop auto-learned domains already covered (exact or by suffix) by the manual OR preset lists —
		# e.g. once googlevideo.com is a manual/preset entry, all the learned rrX.googlevideo.com are redundant
		before=$(z2_count "$Z2_AUTO")
		cov=$(cat "$Z2_USER" "$Z2_MAIN" 2>/dev/null | sed 's/\r$//; s/[[:space:]]//g' | grep -vE '^($|#)' | tr 'A-Z' 'a-z' | sort -u)
