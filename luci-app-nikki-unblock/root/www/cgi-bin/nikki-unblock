[ "$API" = "iplist" ] && { iplist_json; exit 0; }
[ "$API" = "presets" ] && {
	json_header
	# `fresh=1` forces a rebuild (manual refresh after editing the applist).
	case "$QUERY_STRING" in *fresh=1*) rm -f "$PRESET_CACHE" ;; esac
	# Serve the cache if it's younger than the TTL (cold build does index.json + N .lst curls ~7 s).
	if [ -f "$PRESET_CACHE" ]; then
		age=$(( $(date +%s) - $(date -r "$PRESET_CACHE" +%s 2>/dev/null || echo 0) ))
		[ "$age" -ge 0 ] && [ "$age" -lt "$PRESET_TTL" ] && { cat "$PRESET_CACHE"; exit 0; }
	fi
	body=$(presets_json)
	# Only cache a well-formed, non-empty array so a transient fetch failure can't pin an empty result.
	case "$body" in \[?*\]) printf '%s' "$body" > "$PRESET_CACHE" ;; esac
	printf '%s' "$body"
	exit 0
}
[ "$API" = "autosync" ] && { autosync_json; exit 0; }
[ "$API" = "versions" ] && { versions_json; exit 0; }
[ "$API" = "updatestatus" ] && { updatestatus_json; exit 0; }
[ "$API" = "config" ] && { config_json; exit 0; }
[ "$API" = "nodes" ] && { nodes_json; exit 0; }
[ "$API" = "svcstatus" ] && {
	json_header
	running=0; pgrep -f /usr/bin/mihomo >/dev/null 2>&1 && running=1
	booten=0; /etc/init.d/nikki enabled 2>/dev/null && booten=1
	# Startup guard: does the configured base_group actually exist in mihomo? A wrong
	# base_group name (profile's proxy-group isn't "PROXY") makes every "→ VPN" rule point
	# at a nonexistent group. Only meaningful while running (down → /proxies won't answer).
	base_ok=1
	[ "$running" = 1 ] && { curl -s -m 5 -H "Authorization: Bearer $(mihomo_secret)" \
		"$MIHOMO_API/proxies/$(urlenc_all "$BASE_GROUP")" 2>/dev/null | grep -q '"name"' || base_ok=0; }
	printf '{"running":%d,"boot":%d,"base_group":"%s","base_ok":%d}' \
		"$running" "$booten" "$BASE_GROUP" "$base_ok"; exit 0
}

