  <div class="banner" id="guard" hidden></div>
  <div class="tabs">
    <button class="tab active" data-view="domains" data-i18n="tabDomains"></button>
    <button class="tab" data-view="ips" data-i18n="tabIps"></button>
    <button class="tab" data-view="nodes" data-i18n="tabNodes"></button>
    <button class="tab" data-view="mgmt" data-i18n="tabMgmt"></button>
  </div>

  <!-- ================= DOMAINS ================= -->
  <section class="view active" id="view-domains">
    <div class="dom-layout">
      <div class="dom-main">
        <form class="add" id="addForm">
          <select id="rtype" data-i18n-title="tType">
            <option value="DOMAIN-SUFFIX" data-i18n="tSuffix"></option>
            <option value="DOMAIN" data-i18n="tDomain"></option>
            <option value="DOMAIN-KEYWORD" data-i18n="tKeyword"></option>
            <option value="GEOSITE">GEOSITE</option>
            <option value="GEOIP">GEOIP</option>
            <option value="IP-CIDR">IP-CIDR</option>
          </select>
          <input id="domain" placeholder="example.com" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" required>
          <select id="rnode" data-i18n-title="nAction">
            <option value="UNBLOCK" data-i18n="nProxy"></option>
            <option value="DIRECT" data-i18n="nDirect"></option>
            <option value="REJECT" data-i18n="nReject"></option>
          </select>
          <button type="submit" id="addBtn" data-i18n="add"></button>
        </form>

        <details class="help">
          <summary data-i18n="helpSummary"></summary>
          <div class="helpbody" data-i18n-html="helpBody"></div>
        </details>

        <div class="row">
          <button type="button" class="ghost" id="modeToggle"></button>
          <span class="count" id="count"></span>
        </div>

        <ul id="list"></ul>

        <div id="bulkWrap" hidden>
          <div class="hint" data-i18n="bulkHint"></div>
          <textarea id="bulk" spellcheck="false"></textarea>
          <div class="row">
            <button type="button" id="saveList" data-i18n="save"></button>
            <button type="button" class="ghost" id="cancelList" data-i18n="cancel"></button>
          </div>
        </div>

        <div class="msg" id="msg"></div>
      </div>

      <aside class="dom-side">
        <h3 data-i18n="unblock"></h3>
        <div class="presets" id="presets"><span class="hint" data-i18n="loading"></span></div>
        <div class="msg" id="presetMsg"></div>

        <div class="autosync">
          <div class="asrow"><label class="sw"><input type="checkbox" id="autoOn"><span class="sl"></span></label> <span data-i18n="autoUpdate"></span></div>
          <select id="autoIv">
            <option value="1h" data-i18n="iv1h"></option>
            <option value="6h" data-i18n="iv6h"></option>
            <option value="12h" data-i18n="iv12h"></option>
            <option value="24h" data-i18n="iv24h"></option>
            <option value="weekly" data-i18n="ivWeekly"></option>
          </select>
          <div class="hint" data-i18n="autoHint"></div>
          <div class="msg" id="autoMsg"></div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ================= IP EXCLUSIONS ================= -->
  <section class="view" id="view-ips">
    <div class="hint" data-i18n="ipHint"></div>
    <form class="add" id="ipForm">
      <input id="ip" placeholder="1.2.3.4  ·  1.2.3.0/24" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" required>
      <button type="submit" id="ipBtn" data-i18n="add"></button>
    </form>
    <div class="msg" id="ipMsg"></div>
    <h3><span data-i18n="exclusions"></span> <span class="count" id="ipCount"></span></h3>
    <ul id="ipList"></ul>
  </section>

  <!-- ================= VPN NODES ================= -->
  <section class="view" id="view-nodes">
    <div class="hint" data-i18n="nodesHint"></div>
    <div id="dropzone" class="dropzone" data-i18n="nodeDrop"></div>
    <textarea id="nodeCfg" spellcheck="false" placeholder="[Interface]…   ·   vless://…   ·   https://sub…   ·   - name: …"></textarea>
