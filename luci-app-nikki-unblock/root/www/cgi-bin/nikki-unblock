	elif [ "$action" = "setlang" ]; then
		lang=$(get_param lang | sed 's/[^a-z]//g'); case "$lang" in ru|en) ;; *) lang=ru ;; esac
		uci set nikki-unblock.config.lang="$lang" 2>/dev/null; uci commit nikki-unblock 2>/dev/null
		json_header; printf '{"ok":true,"lang":"%s"}' "$lang"; exit 0

	elif [ "$action" = "nodeadd" ]; then
		mkdir -p "$NODES_DIR" "$PROV_DIR"
		raw=$(get_param config | sed 's/\r//g')
		nm=$(get_param name)
		fl=$(printf '%s' "$raw" | grep -vE '^[[:space:]]*$' | head -1)
		err=""; kind=node; yaml=""; id=""; pid=""; subid=""
		case "$fl" in
		"[Interface]"*)
			WGCONF="/tmp/nu-wg.$$"; printf '%s\n' "$raw" > "$WGCONF"
			[ -z "$nm" ] && nm="wg-$(grep -iE '^Endpoint' "$WGCONF" | head -1 | sed 's/.*=//; s/[[:space:]]//g; s/:.*//; s/\./-/g')"
			[ "$(grep -ic '^Jc' "$WGCONF")" -ge 1 ] && nm=$(printf '%s' "$nm" | sed 's/^wg-/awg-/')
			yaml=$(wg_to_yaml "$nm"); rm -f "$WGCONF"
			;;
		vless://*|vmess://*|trojan://*|ss://*|hysteria2://*|hy2://*|tuic://*)
			[ -z "$nm" ] && { nm=$(printf '%s' "$fl" | sed 's/.*#//'); nm=$(urldec "$nm"); }
			[ -z "$nm" ] && nm="link-node"
			yaml=$(sharelink_to_yaml "$fl" "$nm") || err="unsupported link type"
			[ -z "$yaml" ] && [ -z "$err" ] && err="could not parse link"
			;;
		http://*|https://*)
			# Fetch the subscription ourselves. Two kinds:
			#  - v2ray/base64 (or plain) list of share-links -> convert each into an individual node
			#    (manageable/orderable; needed because clash-UA output is often empty, e.g. remnawave).
			#  - real clash YAML with proxies: -> keep as an auto-updating proxy-provider (as before).
			subbody=$(curl -s --max-time 20 "$fl" 2>/dev/null)
			subdec=$(printf '%s' "$subbody" | b64d)
			if printf '%s\n%s\n' "$subdec" "$subbody" | grep -qiE '^(vless|vmess|trojan|ss|hysteria2|hy2|tuic)://'; then
				kind=multi; [ -z "$nm" ] && nm="sub"   # tracked link-subscription -> individual nodes (sub_sync)
			elif printf '%s' "$subbody" | grep -q 'proxies:'; then
				kind=provider; [ -z "$nm" ] && nm="sub-$(date +%s)"; pid=$(san_name "$nm")
				{ echo "  $pid:"; echo "    type: http"; echo "    url: $fl"; echo "    interval: 86400"
				  echo "    health-check: {enable: true, url: http://cp.cloudflare.com/generate_204, interval: 300}"; } > "$PROV_DIR/$pid.yaml"
			else
				err="subscription returned no usable nodes"
			fi
			;;
		*)
			# raw clash/mihomo proxy: a mapping or a "- name:" item. Normalize to a 1-item seq at
			# 2-space list indent via yq (robust to the pasted indentation), then reindent under nikki-proxies.
			_rf="/tmp/nu-raw.$$"; printf '%s\n' "$raw" > "$_rf"
			yaml=$(yq -M -o=yaml '[ (.[0] // .) ]' "$_rf" 2>/dev/null | sed 's/^/  /')
			rm -f "$_rf"
			case "$yaml" in *name:*) ;; *) err="need a valid clash proxy (a mapping or '- name:' item)"; yaml="" ;; esac
			[ -z "$nm" ] && nm=$(printf '%s' "$yaml" | grep -m1 'name:' | sed 's/.*name:[[:space:]]*//; s/[",]//g')
			;;
		esac
		[ -n "$err" ] && { json_header; printf '{"ok":false,"error":"%s"}' "$err"; exit 0; }
		multiids=""
		if [ "$kind" = node ]; then
			# ensure a unique proxy name — mihomo rejects a name that collides with the profile or another node
			b="$nm"; k=1
			while [ "$k" -lt 30 ] && name_taken "$nm"; do k=$((k+1)); nm="$b-$k"; done
			[ "$nm" = "$b" ] || yaml=$(printf '%s\n' "$yaml" | awk -v n="$nm" 'BEGIN{d=0} /name:/&&!d{sub(/name:.*/,"name: " n);d=1} {print}')
			id=$(san_name "$nm"); [ -z "$id" ] && id="node-$(date +%s)"
			printf '%s\n' "$yaml" > "$NODES_DIR/$id.yaml"
		elif [ "$kind" = multi ]; then
			# a tracked link-subscription: create its record + import nodes via sub_sync (refreshable later)
			mkdir -p "$SUBS_DIR"
			subid=$(san_name "$nm"); [ -z "$subid" ] && subid="sub-$(date +%s)"
			# avoid clobbering an existing sub of the same name
			[ -f "$SUBS_DIR/$subid.conf" ] && subid="$subid-$(date +%s)"
			{ printf 'url=%s\n' "$fl"; printf 'name=%s\n' "$nm"; } > "$SUBS_DIR/$subid.conf"
			if ! sub_sync "$subid" "$fl" "$nm"; then
				rm -f "$SUBS_DIR/$subid.conf"; json_header; printf '{"ok":false,"error":"no links could be parsed"}'; exit 0
			fi
			added=$(sub_owned_ids "$subid" | grep -c .)
			multiids=$(sub_owned_ids "$subid" | tr '\n' ' ')
			# auto-refresh is on by default — make sure the cron exists now that a subscription exists
			if subauto_on; then
				_siv=$(uci -q get nikki-unblock.config.subauto_interval 2>/dev/null); [ -z "$_siv" ] && _siv=24h
				subauto_set 1 "$_siv"
			fi
		fi
		protect_all_nodes   # shield the new node's server from zapret2 + add it to nikki's loop bypass
		regen_mixin; apply_nikki; sleep 6
		if ! pgrep -f /usr/bin/mihomo >/dev/null; then
			# config broke nikki -> roll back and report
			rm -f "$NODES_DIR/$id.yaml" "$PROV_DIR/$pid.yaml"
			for x in $multiids; do rm -f "$NODES_DIR/$x.yaml" "$NODES_DIR/$x.src"; done
			[ -n "$subid" ] && rm -f "$SUBS_DIR/$subid.conf"
			regen_mixin; apply_nikki
			json_header; printf '{"ok":false,"error":"config rejected by mihomo (reverted)"}'; exit 0
		fi
		if [ "$kind" = node ]; then
			rn=$(grep -m1 'name:' "$NODES_DIR/$id.yaml" | sed 's/.*name:[[:space:]]*//')
			json_header; printf '{"ok":true,"kind":"node","id":"%s","name":"%s","delay":"%s"}' "$id" "$rn" "$(mihomo_delay "$rn")"; exit 0
		elif [ "$kind" = multi ]; then
			json_header; printf '{"ok":true,"kind":"multi","added":%d}' "$added"; exit 0
		fi
		json_header; printf '{"ok":true,"kind":"provider","id":"%s"}' "$pid"; exit 0

	elif [ "$action" = "nodedel" ]; then
		id=$(get_param id | sed 's/[^a-z0-9_-]//g')
		if [ -n "$id" ]; then
			nm=$(grep -m1 'name:' "$NODES_DIR/$id.yaml" 2>/dev/null | sed 's/.*name:[[:space:]]*//')
			rm -f "$NODES_DIR/$id.yaml" "$NODES_DIR/$id.off" "$NODES_DIR/$id.src" "$PROV_DIR/$id.yaml"
			# drop the name from the order/off lists too
			for L in "$ORDER_FILE" "$OFF_FILE"; do
				[ -n "$nm" ] && [ -f "$L" ] && { grep -vxF "$nm" "$L" > "$L.tmp" 2>/dev/null; mv "$L.tmp" "$L"; }
			done
		fi
		regen_mixin; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

	elif [ "$action" = "nodecheck" ]; then
		id=$(get_param id | sed 's/[^a-z0-9_-]//g')
		rn=$(grep -m1 'name:' "$NODES_DIR/$id.yaml" 2>/dev/null | sed 's/.*name:[[:space:]]*//')
		# fall back to the raw name param (profile nodes aren't in our store) for a live probe
		[ -z "$rn" ] && rn=$(get_param name)
		[ -z "$rn" ] && { json_header; printf '{"ok":false,"error":"not found"}'; exit 0; }
		json_header; printf '{"ok":true,"delay":"%s"}' "$(mihomo_delay "$rn")"; exit 0

	elif [ "$action" = "nodetoggle" ]; then
		# toggle a node (profile OR ours) on/off by NAME via the shared off-list
		nm=$(get_param name)
		[ -z "$nm" ] && { json_header; printf '{"ok":false,"error":"no name"}'; exit 0; }
		touch "$OFF_FILE"
		if grep -qxF "$nm" "$OFF_FILE"; then
			grep -vxF "$nm" "$OFF_FILE" > "$OFF_FILE.tmp"; mv "$OFF_FILE.tmp" "$OFF_FILE"; en=1
		else
			printf '%s\n' "$nm" >> "$OFF_FILE"; en=0
		fi
		regen_mixin; apply_nikki; sleep 6
		if ! pgrep -f /usr/bin/mihomo >/dev/null; then
			if [ "$en" = 1 ]; then printf '%s\n' "$nm" >> "$OFF_FILE"; else grep -vxF "$nm" "$OFF_FILE" > "$OFF_FILE.tmp"; mv "$OFF_FILE.tmp" "$OFF_FILE"; fi
			regen_mixin; apply_nikki
			json_header; printf '{"ok":false,"error":"reload failed (reverted)"}'; exit 0
		fi
		json_header; printf '{"ok":true,"enabled":%s}' "$en"; exit 0

	elif [ "$action" = "nodeorder" ]; then
		# names = the full ordered list of exit node names, newline-separated
		get_param names | sed 's/[[:space:]]*$//' | awk 'NF' > "$ORDER_FILE"
		regen_mixin; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

	elif [ "$action" = "nodemode" ]; then
		m=$(get_param mode | sed 's/[^a-z-]//g'); case "$m" in urltest|fallback) ;; *) m=fallback ;; esac
		uci set nikki-unblock.config.node_mode="$m" 2>/dev/null; uci commit nikki-unblock 2>/dev/null
		regen_mixin; apply_nikki; sleep 3
		pgrep -f /usr/bin/mihomo >/dev/null || apply_nikki
		json_header; printf '{"ok":true,"mode":"%s"}' "$m"; exit 0

	elif [ "$action" = "migraterules" ]; then
		# move all "→ VPN" rules from the raw profile group ($BASE_GROUP) onto the managed exit group
		regen_mixin   # make sure UNBLOCK exists before rules point at it
		i=0; changed=0
		while uci -q get "nikki.@rule[$i]" >/dev/null 2>&1; do
			[ "$(uci -q get "nikki.@rule[$i].node")" = "$BASE_GROUP" ] && { uci set "nikki.@rule[$i].node=$EXIT_GROUP"; changed=$((changed + 1)); }
			i=$((i + 1))
		done
		[ "$changed" -gt 0 ] && uci commit nikki
		apply_nikki; sleep 4
		pgrep -f /usr/bin/mihomo >/dev/null || apply_nikki
		json_header; printf '{"ok":true,"changed":%d}' "$changed"; exit 0

	elif [ "$action" = "subrefresh" ]; then
		sid=$(get_param id | sed 's/[^a-z0-9_-]//g')
		[ -f "$SUBS_DIR/$sid.conf" ] || { json_header; printf '{"ok":false,"error":"no sub"}'; exit 0; }
		url=$(grep -m1 '^url=' "$SUBS_DIR/$sid.conf" | cut -d= -f2-); snm=$(grep -m1 '^name=' "$SUBS_DIR/$sid.conf" | cut -d= -f2-)
		BK="/tmp/nu-subbk.$$"; rm -rf "$BK"; mkdir -p "$BK"; cp "$NODES_DIR"/* "$BK/" 2>/dev/null
		if sub_sync "$sid" "$url" "$snm"; then
			protect_all_nodes   # protect any new node servers from zapret2 + nikki loop
			regen_mixin; apply_nikki; sleep 6
			if ! pgrep -f /usr/bin/mihomo >/dev/null; then
				rm -f "$NODES_DIR"/*.yaml "$NODES_DIR"/*.src 2>/dev/null; cp "$BK"/* "$NODES_DIR/" 2>/dev/null
				regen_mixin; apply_nikki; rm -rf "$BK"
				json_header; printf '{"ok":false,"error":"refresh broke mihomo (reverted)"}'; exit 0
			fi
			rm -rf "$BK"; json_header; printf '{"ok":true,"count":%d}' "$(sub_owned_ids "$sid" | grep -c .)"; exit 0
		fi
		rm -rf "$BK"; json_header; printf '{"ok":false,"error":"subscription empty/unreachable"}'; exit 0

	elif [ "$action" = "subdel" ]; then
		sid=$(get_param id | sed 's/[^a-z0-9_-]//g')
		for oid in $(sub_owned_ids "$sid"); do
			onm=$(node_name_of "$oid"); rm -f "$NODES_DIR/$oid.yaml" "$NODES_DIR/$oid.src"
			for L in "$ORDER_FILE" "$OFF_FILE"; do [ -f "$L" ] && [ -n "$onm" ] && { grep -vxF "$onm" "$L" > "$L.t" 2>/dev/null; mv "$L.t" "$L"; }; done
		done
		rm -f "$SUBS_DIR/$sid.conf"
		regen_mixin; apply_nikki
		json_header; printf '{"ok":true}'; exit 0

	elif [ "$action" = "subauto" ]; then
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		iv=$(get_param interval | sed 's/[^0-9a-z]//g'); [ -z "$iv" ] && iv=24h
		subauto_set "$on" "$iv"
		json_header; printf '{"ok":true,"enabled":%s,"interval":"%s"}' "$([ "$on" = 1 ] && echo true || echo false)" "$iv"; exit 0

	elif [ "$action" = "backupauto" ]; then
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		backupauto_set "$on"
		[ "$on" = 1 ] && backup_auto_run   # write one immediately so there's something to restore
		json_header; printf '{"ok":true,"enabled":%s}' "$([ "$on" = 1 ] && echo true || echo false)"; exit 0

	elif [ "$action" = "mssclamp" ]; then
		on=$(get_param on | sed 's/[^01]//g'); [ -z "$on" ] && on=0
		mssclamp_set "$on"
		json_header; printf '{"ok":true,"enabled":%s}' "$([ "$on" = 1 ] && echo true || echo false)"; exit 0
	fi

	json_header; printf '{"ok":false,"error":"unknown action"}'; exit 0
fi

# ---- LAN device exclusions (keep a device's traffic OFF the tunnel, by source IP) ----------
# Uses nikki's `lan_access_control` (matches by IP only, no MAC): an entry with proxy=0 excludes
# that device. Device names come from DHCP leases + static hosts so the UI can offer a picker.
lan_devices() {   # prints "ip<TAB>mac<TAB>name" per known LAN device (static names win)
	{
		j=0
		while uci -q get "dhcp.@host[$j]" >/dev/null 2>&1; do
			hip=$(uci -q get "dhcp.@host[$j].ip"); hmac=$(uci -q get "dhcp.@host[$j].mac"); hnm=$(uci -q get "dhcp.@host[$j].name")
			[ -n "$hip" ] && printf '%s\t%s\t%s\n' "$hip" "$hmac" "$hnm"
			j=$((j + 1))
		done
		awk '{ h=$4; if (h=="*") h=""; printf "%s\t%s\t%s\n", $3, $2, h }' /tmp/dhcp.leases 2>/dev/null
	} | awk -F'\t' '$1!="" && !seen[$1]++'
}
devices_json() {
	json_header
	_dt="/tmp/nu-dev.$$"; lan_devices > "$_dt" 2>/dev/null
	exips=" "; exc=""; i=0
	while uci -q get "nikki.@lan_access_control[$i]" >/dev/null 2>&1; do
		dip=$(uci -q get "nikki.@lan_access_control[$i].ip"); dpx=$(uci -q get "nikki.@lan_access_control[$i].proxy")
		if [ -n "$dip" ] && [ "$dpx" = 0 ]; then
			exips="$exips$dip "
			dnm=$(awk -F'\t' -v ip="$dip" '$1==ip{print $3; exit}' "$_dt")
			exc="$exc${exc:+,}{\"ip\":\"$(json_esc "$dip")\",\"name\":\"$(json_esc "$dnm")\"}"
		fi
		i=$((i + 1))
	done
	known=""
	while IFS=$(printf '\t') read -r kip kmac knm; do
		case "$exips" in *" $kip "*) continue ;; esac
		known="$known${known:+,}{\"ip\":\"$(json_esc "$kip")\",\"mac\":\"$(json_esc "$kmac")\",\"name\":\"$(json_esc "$knm")\"}"
	done < "$_dt"
	rm -f "$_dt"
	printf '{"excluded":[%s],"known":[%s]}' "$exc" "$known"
}

[ "$API" = "list" ] && { list_json; exit 0; }
[ "$API" = "iplist" ] && { iplist_json; exit 0; }
[ "$API" = "devices" ] && { devices_json; exit 0; }
[ "$API" = "z2status" ] && { z2status_json; exit 0; }
[ "$API" = "ytdiag" ] && { ytdiag_json; exit 0; }
[ "$API" = "z2hosts" ] && { z2hosts_json; exit 0; }
[ "$API" = "z2presets" ] && { z2presets_json; exit 0; }
[ "$API" = "presets" ] && {
	json_header
	# `fresh=1` forces a rebuild (manual refresh after editing the applist).
	case "$QUERY_STRING" in *fresh=1*) rm -f "$PRESET_CACHE" ;; esac
	# Serve the cache if it's younger than the TTL (cold build does index.json + N .lst curls ~7 s).
	if [ -f "$PRESET_CACHE" ]; then
		age=$(( $(date +%s) - $(date -r "$PRESET_CACHE" +%s 2>/dev/null || echo 0) ))
		[ "$age" -ge 0 ] && [ "$age" -lt "$PRESET_TTL" ] && { cat "$PRESET_CACHE"; exit 0; }
	fi
	body=$(presets_json)
	# Only cache a well-formed, non-empty array so a transient fetch failure can't pin an empty result.
	case "$body" in \[?*\]) printf '%s' "$body" > "$PRESET_CACHE" ;; esac
	printf '%s' "$body"
	exit 0
}
[ "$API" = "autosync" ] && { autosync_json; exit 0; }
[ "$API" = "versions" ] && { versions_json; exit 0; }
[ "$API" = "diag" ] && { diag_json; exit 0; }
[ "$API" = "updcheck" ] && { updcheck_json; exit 0; }
[ "$API" = "subauto" ] && { subauto_json; exit 0; }
[ "$API" = "backupauto" ] && { backupauto_json; exit 0; }
[ "$API" = "presetop" ] && { presetop_json; exit 0; }
[ "$API" = "undolist" ] && { undolist_json; exit 0; }
[ "$API" = "updatestatus" ] && { updatestatus_json; exit 0; }
[ "$API" = "config" ] && { config_json; exit 0; }
[ "$API" = "nodes" ] && { nodes_json; exit 0; }
[ "$API" = "svcstatus" ] && {
	json_header
	running=0; pgrep -f /usr/bin/mihomo >/dev/null 2>&1 && running=1
	booten=0; /etc/init.d/nikki enabled 2>/dev/null && booten=1
	# Startup guard: does the configured base_group actually exist in mihomo? A wrong
	# base_group name (profile's proxy-group isn't "PROXY") makes every "→ VPN" rule point
	# at a nonexistent group. Only meaningful while running (down → /proxies won't answer).
	base_ok=1
	[ "$running" = 1 ] && { curl -s -m 5 -H "Authorization: Bearer $(mihomo_secret)" \
		"$MIHOMO_API/proxies/$(urlenc_all "$BASE_GROUP")" 2>/dev/null | grep -q '"name"' || base_ok=0; }
	mss=0; mssclamp_on && mss=1
	printf '{"running":%d,"boot":%d,"base_group":"%s","base_ok":%d,"mss":%d}' \
		"$running" "$booten" "$BASE_GROUP" "$base_ok" "$mss"; exit 0
}

