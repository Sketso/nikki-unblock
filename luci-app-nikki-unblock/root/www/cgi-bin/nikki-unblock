		case "$ip" in */*) ;; *:*) ;; *) ip="$ip/32" ;; esac
		case "$ip" in *.*|*:*) ;; *) json_header; printf '{"ok":false,"error":"bad ip"}'; exit 0 ;; esac
		for e in $(uci -q get nikki.proxy.reserved_ip); do
			[ "$e" = "$ip" ] && { json_header; printf '{"ok":true,"dup":true}'; exit 0; }
