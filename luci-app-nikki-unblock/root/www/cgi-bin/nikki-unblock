      <input id="nodeName" data-i18n-ph="nodeName" autocomplete="off" autocapitalize="off" spellcheck="false">
      <button type="submit" id="nodeBtn" data-i18n="nodeAdd"></button>
    </form>
    <div class="msg" id="nodeMsg"></div>

    <div class="exithead">
      <h3><span data-i18n="exitsTitle"></span></h3>
