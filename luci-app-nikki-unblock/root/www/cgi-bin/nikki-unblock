		body=$(z2_strat_body "$id")
		[ -z "$body" ] && { json_header; printf '{"ok":false,"error":"bad strategy"}'; exit 0; }
		[ -f "$Z2_CONFIG" ] || { json_header; printf '{"ok":false,"error":"no config"}'; exit 0; }
